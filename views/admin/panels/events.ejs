<!-- views/admin/panels/events.ejs -->
<div class="row g-4">
  <!-- Add Event Form -->
  <div class="col-xl-4" data-aos="fade-right">
    <div class="dashboard-block h-100">
      <div class="block-header">
        <h2 class="block-title">Create New Event</h2>
      </div>
      <form action="/events/add" method="POST" enctype="multipart/form-data" class="mt-2">
        <div class="mb-3">
          <label class="form-label text-muted small">Event Title</label>
          <input type="text" name="title" class="form-control form-control-custom" placeholder="e.g. Innovista 2026" required>
        </div>
        <div class="mb-3">
          <label class="form-label text-muted small">Event Type</label>
          <select name="type" class="form-select form-control-custom" required>
            <option value="upcoming">Upcoming</option>
            <option value="live">Live</option>
            <option value="past">Past</option>
          </select>
        </div>
        <div class="mb-3">
          <label class="form-label text-muted small">Short Description (with Category/Location)</label>
          <input type="text" name="shortDescription" class="form-control form-control-custom" placeholder="e.g. Category: Technical | Location: SVNIT Surat" required>
        </div>
        <div class="mb-3">
          <label class="form-label text-muted small">Description</label>
          <textarea name="description" rows="3" class="form-control form-control-custom" placeholder="Detailed description..." required></textarea>
        </div>
        <div class="mb-3">
          <label class="form-label text-muted small">About (Detailed schedule highlights)</label>
          <textarea name="about" rows="3" class="form-control form-control-custom" placeholder="Highlights, schedules..." required></textarea>
        </div>
        <div class="row g-2 mb-3">
          <div class="col-6">
            <label class="form-label text-muted small">Start Date</label>
            <input type="date" name="startDate" class="form-control form-control-custom" required>
          </div>
          <div class="col-6">
            <label class="form-label text-muted small">End Date</label>
            <input type="date" name="endDate" class="form-control form-control-custom" required>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label text-muted small">External Reg Link (Optional)</label>
          <input type="url" name="registrationLink" class="form-control form-control-custom" placeholder="https://...">
        </div>
        <div class="mb-3">
          <label class="form-label text-muted small">Is Public / Visible?</label>
          <select name="isPublic" class="form-select form-control-custom">
            <option value="true">Public (Visible to all users)</option>
            <option value="false">Private / Draft</option>
          </select>
        </div>
        <div class="mb-4">
          <label class="form-label text-muted small">Banner Image</label>
          <input type="file" name="bannerImage" class="form-control form-control-custom" accept="image/*" required>
        </div>
        <button type="submit" class="btn-gold w-100 py-2">Create Event</button>
      </form>
    </div>
  </div>

  <!-- Event Listing -->
  <div class="col-xl-8" data-aos="fade-left">
    <div class="dashboard-block h-100">
      <div class="block-header">
        <h2 class="block-title">All Events (<%= events.length %>)</h2>
      </div>
      <div class="table-responsive mt-3" style="max-height: 700px; overflow-y: auto;">
        <table class="admin-table">
          <thead>
            <tr>
              <th>Image</th>
              <th>Details</th>
              <th>Status</th>
              <th>Visibility</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (events && events.length > 0) { %>
              <% events.forEach(event => { %>
                <tr>
                  <td>
                    <img src="<%= event.bannerImage || '/images/aayam_img.jpg' %>" alt="Banner" style="width: 70px; height: 45px; object-fit: cover; border-radius: 6px; border: 1px solid var(--db-border);">
                  </td>
                  <td>
                    <div style="font-weight: 600; font-size: 0.95rem; color: var(--cream-light);"><%= event.title %></div>
                    <div style="font-size: 0.78rem; color: var(--text-muted);">
                      <%= event.startDate ? new Date(event.startDate).toLocaleDateString('en-IN') : '' %> - 
                      <%= event.endDate ? new Date(event.endDate).toLocaleDateString('en-IN') : '' %>
                    </div>
                  </td>
                  <td>
                    <form action="/events/change-status/<%= event._id %>" method="POST" class="d-inline">
                      <select name="type" class="form-select form-select-sm form-control-custom" style="padding: 2px 24px 2px 8px; font-size: 0.8rem; width: auto;" onchange="this.form.submit()">
                        <option value="upcoming" <%= event.type === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
                        <option value="live" <%= event.type === 'live' ? 'selected' : '' %>>Live</option>
                        <option value="past" <%= event.type === 'past' ? 'selected' : '' %>>Past</option>
                      </select>
                    </form>
                  </td>
                  <td>
                    <span class="badge-role <%= event.isPublic !== false ? 'badge-active' : 'badge-disabled' %>">
                      <%= event.isPublic !== false ? 'Public' : 'Draft' %>
                    </span>
                  </td>
                  <td class="text-end">
                    <div style="display: flex; gap: 6px; justify-content: flex-end; flex-wrap: wrap;">
                      <a href="/events/edit/<%= event._id %>" class="btn btn-sm btn-outline-warning" style="font-size: 0.8rem; border-radius: 8px;">
                        <i class="bi bi-pencil-square"></i> Customize
                      </a>
                      <form action="/events/toggle-visibility/<%= event._id %>" method="POST" class="d-inline">
                        <button class="btn btn-sm btn-outline-secondary" style="font-size: 0.8rem; border-radius: 8px;">
                          Toggle View
                        </button>
                      </form>
                      <form action="/events/delete/<%= event._id %>" method="POST" class="d-inline" onsubmit="return confirm('Delete this event and all its registrations?')">
                        <button class="btn btn-sm btn-admin-danger" style="font-size: 0.8rem; border-radius: 8px;">
                          <i class="bi bi-trash"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
                <!-- Subevents list for this event -->
                <tr style="background: rgba(166, 124, 82, 0.02);">
                  <td colspan="5" style="padding: 8px 24px; border-bottom: 2px solid var(--db-border);">
                    <div class="d-flex align-items-center flex-wrap gap-2 text-muted small">
                      <span class="fw-semibold text-warning"><i class="bi bi-diagram-3"></i> Sub-events Forms:</span>
                      <% 
                        const subs = allSubs.filter(s => s.eventId.toString() === event._id.toString());
                        if (subs.length > 0) {
                          subs.forEach(s => {
                      %>
                            <div class="badge bg-secondary d-flex align-items-center gap-1 p-2" style="font-size: 0.75rem; border: 1px solid var(--db-border);">
                              <%= s.title %>
                              <a href="/admin/subevents/<%= s._id %>/registrations" class="text-warning small ms-1" title="View registrations">
                                <i class="bi bi-people-fill"></i> Registrations
                              </a>
                            </div>
                      <% 
                          });
                        } else {
                      %>
                          <span class="fst-italic">No registration forms. Create one by clicking 'Customize' above.</span>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="5" class="text-center text-muted py-4">No events found. Create one using the form on the left.</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
