<!-- views/admin/panels/gallery.ejs -->
<div class="row g-4">
  
  <!-- Homepage Gallery Section Managers -->
  <div class="col-xl-6" data-aos="fade-right">
    <div class="dashboard-block h-100">
      <div class="block-header">
        <h2 class="block-title">Homepage Gallery Images</h2>
      </div>
      <p class="text-muted small mt-2 mb-4">You can upload a maximum of <strong>4 images per section</strong> for display on the main website sections.</p>

      <!-- What We Do section -->
      <div class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h3 style="font-size: 1.05rem; font-weight: 600; color: var(--gold);" class="m-0">Section: What We Do</h3>
          <% 
            const wwdImages = galleryItems.filter(img => img.section === 'what_we_do');
          %>
          <span class="badge bg-secondary font-monospace"><%= wwdImages.length %>/4 Uploaded</span>
        </div>

        <% if (wwdImages.length < 4) { %>
          <form action="/home/upload" method="POST" enctype="multipart/form-data" class="row g-2 mb-3 align-items-center">
            <input type="hidden" name="section" value="what_we_do">
            <div class="col-sm-8">
              <input type="file" name="image" class="form-control form-control-custom form-control-sm" accept="image/*" required>
            </div>
            <div class="col-sm-4">
              <button type="submit" class="btn-gold w-100 py-1" style="font-size: 0.85rem;">Upload Image</button>
            </div>
          </form>
        <% } else { %>
          <div class="alert alert-warning p-2 small" style="background: rgba(201, 168, 76, 0.08); border-color: var(--db-border);">
            Limit of 4 images reached for What We Do. Delete an image to upload a new one.
          </div>
        <% } %>

        <div class="row g-2 mt-2">
          <% if (wwdImages.length > 0) { %>
            <% wwdImages.forEach(img => { %>
              <div class="col-sm-6 col-md-3">
                <div class="position-relative" style="aspect-ratio: 4/3; border-radius: 8px; overflow: hidden; border: 1.5px solid var(--db-border);">
                  <img src="<%= img.image.startsWith('/') ? img.image : '/' + img.image %>" alt="WWD Image" style="width:100%; height:100%; object-fit: cover;">
                  <form action="/home/delete/<%= img._id %>" method="POST" class="position-absolute top-0 end-0 m-1" onsubmit="return confirm('Delete this image?')">
                    <button type="submit" class="btn btn-sm btn-danger p-1" style="line-height:1; border-radius: 50%; font-size: 0.72rem;" title="Delete image">✕</button>
                  </form>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p class="text-muted small italic">No images in this section.</p>
          <% } %>
        </div>
      </div>

      <!-- Events gallery section -->
      <div>
        <div class="d-flex justify-content-between align-items-center mb-3">
          <h3 style="font-size: 1.05rem; font-weight: 600; color: var(--gold);" class="m-0">Section: Event Scope Highlights</h3>
          <% 
            const highlights = galleryItems.filter(img => img.section === 'events');
          %>
          <span class="badge bg-secondary font-monospace"><%= highlights.length %>/4 Uploaded</span>
        </div>

        <% if (highlights.length < 4) { %>
          <form action="/home/upload" method="POST" enctype="multipart/form-data" class="row g-2 mb-3 align-items-center">
            <input type="hidden" name="section" value="events">
            <div class="col-sm-8">
              <input type="file" name="image" class="form-control form-control-custom form-control-sm" accept="image/*" required>
            </div>
            <div class="col-sm-4">
              <button type="submit" class="btn-gold w-100 py-1" style="font-size: 0.85rem;">Upload Image</button>
            </div>
          </form>
        <% } else { %>
          <div class="alert alert-warning p-2 small" style="background: rgba(201, 168, 76, 0.08); border-color: var(--db-border);">
            Limit of 4 images reached for Event Scope. Delete an image to upload a new one.
          </div>
        <% } %>

        <div class="row g-2 mt-2">
          <% if (highlights.length > 0) { %>
            <% highlights.forEach(img => { %>
              <div class="col-sm-6 col-md-3">
                <div class="position-relative" style="aspect-ratio: 4/3; border-radius: 8px; overflow: hidden; border: 1.5px solid var(--db-border);">
                  <img src="<%= img.image.startsWith('/') ? img.image : '/' + img.image %>" alt="Scope Highlight" style="width:100%; height:100%; object-fit: cover;">
                  <form action="/home/delete/<%= img._id %>" method="POST" class="position-absolute top-0 end-0 m-1" onsubmit="return confirm('Delete this image?')">
                    <button type="submit" class="btn btn-sm btn-danger p-1" style="line-height:1; border-radius: 50%; font-size: 0.72rem;" title="Delete image">✕</button>
                  </form>
                </div>
              </div>
            <% }) %>
          <% } else { %>
            <p class="text-muted small italic">No images in this section.</p>
          <% } %>
        </div>
      </div>

    </div>
  </div>

  <!-- Homepage Promo Banners -->
  <div class="col-xl-6" data-aos="fade-left">
    <div class="dashboard-block h-100">
      <div class="block-header">
        <h2 class="block-title">Promotional Banners (Register Now Panel)</h2>
      </div>
      
      <!-- Promo Banner Form -->
      <form action="/home/promo/add" method="POST" class="mt-3 p-3 mb-4" style="border: 1px dashed var(--db-border); border-radius: 12px; background: var(--db-surface-alt);">
        <div class="fw-bold text-warning mb-3 small"><i class="bi bi-megaphone"></i> Deploy New Banner</div>
        
        <div class="mb-3">
          <label class="form-label text-muted small">Banner Title</label>
          <input type="text" name="title" class="form-control form-control-custom form-control-sm" placeholder="e.g. Prayaas 2026 Registration" required>
        </div>
        <div class="row g-2 mb-3">
          <div class="col-6">
            <label class="form-label text-muted small">Badge Label</label>
            <input type="text" name="label" class="form-control form-control-custom form-control-sm" placeholder="e.g. Register Now">
          </div>
          <div class="col-6">
            <label class="form-label text-muted small">Heading Accent</label>
            <input type="text" name="heading" class="form-control form-control-custom form-control-sm" placeholder="e.g. Limited Seats">
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label text-muted small">Short Description</label>
          <textarea name="description" rows="2" class="form-control form-control-custom form-control-sm" placeholder="Brief tagline..."></textarea>
        </div>
        <div class="row g-2 mb-3">
          <div class="col-6">
            <label class="form-label text-muted small">Target Registration Link</label>
            <input type="text" name="link" class="form-control form-control-custom form-control-sm" placeholder="e.g. /events/...">
          </div>
          <div class="col-6">
            <label class="form-label text-muted small">Event/Deadline Date</label>
            <input type="date" name="eventDate" class="form-control form-control-custom form-control-sm">
          </div>
        </div>
        <button type="submit" class="btn-gold w-100 py-1" style="font-size: 0.85rem;">Deploy & Activate Banner</button>
      </form>

      <div class="mt-3">
        <div class="fw-bold small mb-3" style="color: var(--cream-light);">Banner History & Deployments</div>
        <% if (promos && promos.length > 0) { %>
          <div class="table-responsive">
            <table class="admin-table text-nowrap">
              <thead>
                <tr>
                  <th>Title</th>
                  <th>Status</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% promos.forEach(promo => { %>
                  <tr>
                    <td class="text-truncate" style="max-width: 180px;">
                      <div style="font-weight: 600; color: var(--cream-light); font-size: 0.88rem;"><%= promo.title %></div>
                      <div class="text-muted small"><%= promo.heading || '' %></div>
                    </td>
                    <td>
                      <span class="badge-role <%= promo.isActive ? 'badge-active' : 'badge-disabled' %>">
                        <%= promo.isActive ? 'Active' : 'Disabled' %>
                      </span>
                    </td>
                    <td class="text-end">
                      <div style="display:flex; gap: 4px; justify-content: flex-end;">
                        <form action="/home/promo/<%= promo._id %>/toggle" method="POST" class="d-inline">
                          <button class="btn btn-sm btn-outline-warning" style="font-size: 0.75rem;">Toggle</button>
                        </form>
                        <form action="/home/promo/<%= promo._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete promo banner?')">
                          <button class="btn btn-sm btn-admin-danger" style="font-size: 0.75rem;">✕</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="text-muted small italic">No promotions created yet.</p>
        <% } %>
      </div>

    </div>
  </div>

</div>
