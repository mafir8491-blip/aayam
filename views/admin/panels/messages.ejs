<!-- views/admin/panels/messages.ejs -->
<div class="dashboard-block" data-aos="fade-up">
  <div class="block-header">
    <h2 class="block-title">Reach Out Messages (<%= messages.length %>)</h2>
  </div>
  
  <div class="table-responsive mt-3" style="max-height: 680px; overflow-y: auto;">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Sender Info</th>
          <th>Subject</th>
          <th>Message Content</th>
          <th>Received At</th>
          <th>Status</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (messages && messages.length > 0) { %>
          <% messages.forEach(msg => { %>
            <tr style="<%= msg.isRead ? '' : 'background: rgba(201, 168, 76, 0.03);' %>">
              <td>
                <div style="font-weight: 600; color: var(--cream-light); font-size: 0.92rem;"><%= msg.name %></div>
                <div class="small text-muted"><i class="bi bi-envelope"></i> <%= msg.email %></div>
                <% if (msg.contact || msg.phone) { %>
                  <div class="small text-muted"><i class="bi bi-telephone"></i> <%= msg.contact || msg.phone %></div>
                <% } %>
                <% if (msg.purpose || msg.heardFrom) { %>
                  <div class="small text-muted mt-1 d-flex gap-1 flex-wrap">
                    <% if (msg.purpose) { %>
                      <span class="badge-role badge-admin" style="font-size:0.68rem; padding: 2px 6px;"><%= msg.purpose %></span>
                    <% } %>
                    <% if (msg.heardFrom) { %>
                      <span class="badge-role badge-super" style="font-size:0.68rem; padding: 2px 6px; background: rgba(166,124,82,0.1); border-color: rgba(166,124,82,0.25); color: #a67c52;"><%= msg.heardFrom %></span>
                    <% } %>
                  </div>
                <% } %>
              </td>
              <td>
                <div style="font-weight: 500; font-size: 0.88rem; color: var(--gold);"><%= msg.subject || 'No Subject' %></div>
              </td>
              <td style="max-width: 320px; white-space: normal; font-size: 0.85rem;">
                <p class="m-0" style="line-height: 1.4; color: var(--cream-light); opacity: 0.85;"><%= msg.message %></p>
              </td>
              <td class="small text-muted">
                <%= msg.createdAt ? new Date(msg.createdAt).toLocaleDateString('en-IN', {day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit'}) : '' %>
              </td>
              <td>
                <span class="badge-role <%= msg.isRead ? 'badge-admin' : 'badge-super' %>">
                  <%= msg.isRead ? 'Read' : 'New/Unread' %>
                </span>
              </td>
              <td class="text-end">
                <div style="display: flex; gap: 6px; justify-content: flex-end;">
                  <form action="/admin/reachout/<%= msg._id %>/toggle-read" method="POST" class="d-inline">
                    <button class="btn btn-sm <%= msg.isRead ? 'btn-outline-secondary' : 'btn-outline-warning' %>" style="font-size: 0.78rem;">
                      <%= msg.isRead ? 'Mark Unread' : 'Mark Read' %>
                    </button>
                  </form>
                  <form action="/admin/reachout/<%= msg._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this message permanently?')">
                    <button class="btn btn-sm btn-admin-danger" style="font-size: 0.78rem;">✕ Delete</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        <% } else { %>
          <tr>
            <td colspan="6" class="text-center text-muted py-5">
              <i class="bi bi-mailbox" style="font-size: 2.5rem; display:block; margin-bottom: 10px; color: var(--text-muted);"></i>
              No messages found.
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>
