<!-- views/admin/reachout/index.ejs -->
<div class="container my-5">

  <!-- ── Header ── -->
  <div class="page-header" data-aos="fade-down">
    <div class="section-label">Admin Inbox</div>
    <%
      var unreadCount = reachouts.filter(function(r){ return !r.isRead; }).length;
      var readItems   = reachouts.filter(function(r){ return  r.isRead; });
      var unreadItems = reachouts.filter(function(r){ return !r.isRead; });
    %>
    <h1 class="page-title" style="display:inline-flex;align-items:center;gap:14px;justify-content:center;flex-wrap:wrap;">
      Reach Out Inbox
      <% if (unreadCount > 0) { %>
        <span class="inbox-badge" id="unreadBadge"><%= unreadCount %> New</span>
      <% } %>
    </h1>
    <p class="page-subtitle">
      <% if (unreadCount > 0) { %>
        <span style="color:#c0392b;font-weight:600;"><%= unreadCount %> unread</span> ·
      <% } else { %>
        <span style="color:#27ae60;font-weight:600;">All caught up</span> ·
      <% } %>
      <%= reachouts.length %> total submission<%= reachouts.length !== 1 ? 's' : '' %>
    </p>
  </div>

  <% if (reachouts.length === 0) { %>
    <div class="gallery-empty" data-aos="fade-up">
      <div class="gallery-empty-icon">📭</div>
      <p>No submissions yet.</p>
    </div>

  <% } else { %>

    <!-- ══════════════════════════════
         NEW / UNREAD SECTION
    ══════════════════════════════ -->
    <div class="inbox-section-hd" data-aos="fade-up">
      <div class="inbox-pill inbox-pill-new">
        <span class="inbox-pill-dot"></span>
        New Messages
        <span class="inbox-pill-num"><%= unreadCount %></span>
      </div>
      <div class="inbox-rule"></div>
    </div>

    <% if (unreadItems.length === 0) { %>
      <div class="inbox-empty-state" data-aos="fade-up">
        <span style="font-size:1.4rem;">✅</span>
        <span>All caught up — no new messages!</span>
      </div>
    <% } %>

    <div id="unreadSection">
      <% unreadItems.forEach(function(item, i) { %>
        <div class="reachout-item unread ro-card" id="card-<%= item._id %>"
          data-aos="fade-up" data-aos-delay="<%= i * 50 %>">

          <div class="ro-top">
            <div class="ro-meta">
              <div style="display:flex;align-items:center;gap:8px;">
                <span class="ro-unread-dot"></span>
                <span class="reachout-name"><%= item.name %></span>
              </div>
              <span class="reachout-email"><%= item.email %></span>
              <% if (item.contact) { %>
                <span class="ro-contact"><i class="bi bi-telephone"></i> <%= item.contact %></span>
              <% } %>
            </div>
            <div class="ro-right">
              <span class="reachout-purpose"><%= item.purpose %></span>
              <span class="ro-time">
                <i class="bi bi-clock"></i>
                <%= new Date(item.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
                &nbsp;·&nbsp;
                <%= new Date(item.createdAt).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) %>
              </span>
            </div>
          </div>

          <p class="reachout-message"><%= item.message %></p>

          <div class="reachout-actions">
            <button class="ro-toggle-btn ro-toggle-read"
              onclick="toggleRead('<%= item._id %>', false)">
              <i class="bi bi-check2-circle"></i> Mark as Read
            </button>
            <form action="/admin/reachout/<%= item._id %>/delete" method="POST"
              onsubmit="return confirm('Delete this submission?')" style="margin:0;">
              <button type="submit" class="btn-admin-danger" style="font-size:0.82rem;padding:7px 14px;">
                <i class="bi bi-trash"></i> Delete
              </button>
            </form>
          </div>
        </div>
      <% }); %>
    </div>

    <!-- ══════════════════════════════
         READ / OLD SECTION
    ══════════════════════════════ -->
    <div class="inbox-section-hd" style="margin-top:40px;" data-aos="fade-up">
      <div class="inbox-pill inbox-pill-read">
        <i class="bi bi-check2-all"></i>
        Read Messages
        <span class="inbox-pill-num inbox-pill-num-green"><%= readItems.length %></span>
      </div>
      <div class="inbox-rule"></div>
      <% if (readItems.length > 0) { %>
        <button class="inbox-toggle-btn" id="readToggleBtn" onclick="toggleReadSection()">
          <i class="bi bi-chevron-up" id="readToggleIcon"></i>
          <span id="readToggleLabel">Hide</span>
        </button>
      <% } %>
    </div>

    <% if (readItems.length === 0) { %>
      <div class="inbox-empty-state inbox-empty-muted" data-aos="fade-up">
        <span style="font-size:1.4rem;">📂</span>
        <span>No read messages yet.</span>
      </div>
    <% } %>

    <div id="readSection">
      <% readItems.forEach(function(item, i) { %>
        <div class="reachout-item ro-card ro-read-card" id="card-<%= item._id %>"
          data-aos="fade-up" data-aos-delay="<%= i * 40 %>">

          <div class="ro-top">
            <div class="ro-meta">
              <span class="reachout-name" style="opacity:0.8;"><%= item.name %></span>
              <span class="reachout-email"><%= item.email %></span>
              <% if (item.contact) { %>
                <span class="ro-contact"><i class="bi bi-telephone"></i> <%= item.contact %></span>
              <% } %>
            </div>
            <div class="ro-right">
              <span class="reachout-purpose"><%= item.purpose %></span>
              <span class="ro-time">
                <i class="bi bi-clock"></i>
                <%= new Date(item.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
                &nbsp;·&nbsp;
                <%= new Date(item.createdAt).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'}) %>
              </span>
            </div>
          </div>

          <p class="reachout-message"><%= item.message %></p>

          <div class="reachout-actions">
            <button class="ro-toggle-btn ro-toggle-unread"
              onclick="toggleRead('<%= item._id %>', true)">
              <i class="bi bi-arrow-counterclockwise"></i> Mark Unread
            </button>
            <form action="/admin/reachout/<%= item._id %>/delete" method="POST"
              onsubmit="return confirm('Delete this submission?')" style="margin:0;">
              <button type="submit" class="btn-admin-danger" style="font-size:0.82rem;padding:7px 14px;">
                <i class="bi bi-trash"></i> Delete
              </button>
            </form>
          </div>
        </div>
      <% }); %>
    </div>

  <% } %>
</div>

<style>
/* ── Badge on title ── */
.inbox-badge {
  display: inline-flex;
  align-items: center;
  padding: 4px 13px;
  border-radius: var(--r-full);
  background: linear-gradient(135deg, #c0392b, #e74c3c);
  color: #fff;
  font-family: var(--font-body);
  font-size: 0.8rem;
  font-weight: 700;
  letter-spacing: 0.5px;
  box-shadow: 0 4px 14px rgba(192,57,43,0.32);
  animation: badgePop 0.55s var(--ease-spring) 0.3s both;
}
@keyframes badgePop {
  from { transform: scale(0) rotate(-8deg); opacity: 0; }
  to   { transform: scale(1) rotate(0deg);  opacity: 1; }
}

/* ── Section headers ── */
.inbox-section-hd {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 18px;
}
.inbox-pill {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 5px 14px;
  border-radius: var(--r-full);
  font-size: 0.73rem;
  font-weight: 700;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  white-space: nowrap;
  flex-shrink: 0;
}
.inbox-pill-new {
  background: rgba(192,57,43,0.09);
  border: 1px solid rgba(192,57,43,0.24);
  color: #c0392b;
}
.inbox-pill-read {
  background: rgba(39,174,96,0.08);
  border: 1px solid rgba(39,174,96,0.22);
  color: #27ae60;
}
body.dark-mode .inbox-pill-new  { background: rgba(192,57,43,0.15); border-color: rgba(192,57,43,0.30); }
body.dark-mode .inbox-pill-read { background: rgba(39,174,96,0.12); border-color: rgba(39,174,96,0.25); }

.inbox-pill-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #c0392b;
  animation: dotPulse 2.2s ease-in-out infinite;
}
.inbox-pill-num {
  background: rgba(192,57,43,0.13);
  color: #c0392b;
  border-radius: var(--r-full);
  padding: 1px 8px;
  font-size: 0.7rem;
  font-weight: 800;
}
.inbox-pill-num-green {
  background: rgba(39,174,96,0.12);
  color: #27ae60;
}
.inbox-rule {
  flex: 1;
  height: 1px;
  background: var(--border-l);
}
body.dark-mode .inbox-rule { background: var(--border-d); }

/* ── Collapse btn ── */
.inbox-toggle-btn {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  background: none;
  border: 1px solid var(--border-l);
  border-radius: var(--r-full);
  padding: 4px 12px;
  font-size: 0.74rem;
  font-weight: 600;
  color: var(--tx-muted);
  cursor: pointer;
  font-family: var(--font-body);
  transition: all 0.22s ease;
  flex-shrink: 0;
}
.inbox-toggle-btn:hover { border-color: var(--br); color: var(--br); }
body.dark-mode .inbox-toggle-btn { border-color: var(--border-d); color: var(--dk-muted); }

/* ── Empty states ── */
.inbox-empty-state {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 20px;
  background: rgba(39,174,96,0.05);
  border: 1px solid rgba(39,174,96,0.16);
  border-radius: var(--r-md);
  color: #27ae60;
  font-size: 0.9rem;
  font-weight: 600;
  margin-bottom: 16px;
}
.inbox-empty-muted {
  background: rgba(166,124,82,0.04);
  border-color: var(--border-l);
  color: var(--tx-muted);
}

/* ── Card layout ── */
.ro-card {
  transition: transform 0.32s var(--ease), opacity 0.32s ease;
}
.ro-card.fly-out {
  transform: translateX(50px) scale(0.96);
  opacity: 0;
  pointer-events: none;
}
.ro-read-card {
  opacity: 0.78;
}
.ro-read-card:hover { opacity: 1; }

.ro-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
  margin-bottom: 10px;
}
.ro-meta {
  display: flex;
  flex-direction: column;
  gap: 3px;
}
.ro-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6px;
  flex-shrink: 0;
}
.ro-time {
  font-size: 0.73rem;
  color: var(--tx-muted);
  display: flex;
  align-items: center;
  gap: 4px;
}
.ro-unread-dot {
  width: 8px; height: 8px;
  border-radius: 50%;
  background: #c0392b;
  box-shadow: 0 0 0 3px rgba(192,57,43,0.18);
  animation: dotPulse 2s ease-in-out infinite;
  flex-shrink: 0;
}
.ro-contact {
  font-size: 0.78rem;
  color: var(--tx-muted);
  display: flex;
  align-items: center;
  gap: 5px;
}

/* ── Toggle read/unread buttons ── */
.ro-toggle-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 15px;
  border-radius: var(--r-full);
  font-size: 0.82rem;
  font-weight: 600;
  font-family: var(--font-body);
  cursor: pointer;
  border: 1.5px solid;
  transition: all 0.24s ease;
}
.ro-toggle-read {
  border-color: rgba(39,174,96,0.35);
  color: #27ae60;
  background: rgba(39,174,96,0.06);
}
.ro-toggle-read:hover {
  background: rgba(39,174,96,0.13);
  border-color: #27ae60;
  transform: translateY(-1px);
}
.ro-toggle-unread {
  border-color: var(--border-l);
  color: var(--tx-muted);
  background: transparent;
}
.ro-toggle-unread:hover {
  border-color: var(--br);
  color: var(--br);
  background: rgba(166,124,82,0.06);
  transform: translateY(-1px);
}
body.dark-mode .ro-toggle-unread { border-color: var(--border-d); color: var(--dk-muted); }
</style>

<script>
// ── Collapse / expand read section ──
var readVisible = true;
function toggleReadSection() {
  var section = document.getElementById('readSection');
  var icon    = document.getElementById('readToggleIcon');
  var label   = document.getElementById('readToggleLabel');
  readVisible = !readVisible;
  section.style.display = readVisible ? '' : 'none';
  icon.className  = readVisible ? 'bi bi-chevron-up' : 'bi bi-chevron-down';
  label.textContent = readVisible ? 'Hide' : 'Show';
}

// ── Animated toggle: slide card out, then reload ──
function toggleRead(id, isCurrentlyRead) {
  var card = document.getElementById('card-' + id);
  if (card) card.classList.add('fly-out');

  setTimeout(function() {
    fetch('/admin/reachout/' + id + '/toggle-read', { method: 'POST' })
      .then(function() { location.reload(); })
      .catch(function() { location.reload(); });
  }, 300);
}
</script>
