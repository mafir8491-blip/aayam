<!-- views/admin/registrations.ejs -->
<div class="container my-5">

  <!-- Header -->
  <div class="page-header" style="text-align:left; padding-top:10px;" data-aos="fade-down">
    <a href="/events/<%= subEvent.eventId %>" class="btn-details" style="margin-bottom:20px;display:inline-flex;">
      <i class="bi bi-arrow-left"></i> Back to Event
    </a>
    <div class="section-label">Admin Panel</div>
    <h1 class="page-title" style="font-size:clamp(1.6rem,3.5vw,2.4rem);"><%= subEvent.title %></h1>
    <p class="page-subtitle">Registration Management</p>
  </div>

  <%
    var totalCount    = registrations.length;
    var verifiedCount = registrations.filter(function(r){ return r.status === 'verified'; }).length;
    var pendingCount  = registrations.filter(function(r){ return r.status === 'pending';  }).length;
    var rejectedCount = registrations.filter(function(r){ return r.status === 'rejected'; }).length;
  %>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:14px;margin-bottom:28px;" data-aos="fade-up">
    <div class="reg-stat-card reg-stat-total">
      <div class="reg-stat-value"><%= totalCount %></div>
      <div class="reg-stat-label">Total</div>
    </div>
    <div class="reg-stat-card reg-stat-verified">
      <div class="reg-stat-value"><%= verifiedCount %></div>
      <div class="reg-stat-label">Verified</div>
    </div>
    <div class="reg-stat-card reg-stat-pending">
      <div class="reg-stat-value"><%= pendingCount %></div>
      <div class="reg-stat-label">Pending</div>
    </div>
    <div class="reg-stat-card reg-stat-rejected">
      <div class="reg-stat-value"><%= rejectedCount %></div>
      <div class="reg-stat-label">Rejected</div>
    </div>
  </div>

  <!-- Toolbar -->
  <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:22px;" data-aos="fade-up">
    <div class="events-toggle-bar" style="margin:0;">
      <button class="evt-tab active" data-tab="all">All (<%= totalCount %>)</button>
      <button class="evt-tab" data-tab="pending">Pending (<%= pendingCount %>)</button>
      <button class="evt-tab" data-tab="verified">Verified (<%= verifiedCount %>)</button>
      <button class="evt-tab" data-tab="rejected">Rejected (<%= rejectedCount %>)</button>
    </div>
    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
      <div style="display:inline-flex;align-items:center;gap:6px;padding:5px 13px;border-radius:var(--r-full);background:rgba(39,174,96,0.09);border:1px solid rgba(39,174,96,0.22);font-size:0.78rem;font-weight:600;color:#27ae60;">
        <span style="width:7px;height:7px;border-radius:50%;background:#27ae60;animation:livePulse 2s ease-in-out infinite;display:inline-block;"></span>
        Live&nbsp;·&nbsp;<span id="countdown">30</span>s
      </div>
      <a href="/admin/subevents/<%= subEvent._id %>/registrations/export" class="btn-details" style="white-space:nowrap;">
        <i class="bi bi-download"></i> Export CSV (<%= totalCount %>)
      </a>
    </div>
  </div>

  <!-- Registration Cards -->
  <div id="registrationsContainer">

    <% if (registrations.length === 0) { %>
      <div class="gallery-empty" id="emptyState" data-aos="fade-up">
        <div class="gallery-empty-icon">📋</div>
        <p>No registrations yet.</p>
      </div>
    <% } %>

    <% for (var idx = 0; idx < registrations.length; idx++) { %>
      <% var reg = registrations[idx]; %>

      <div class="registration-card" data-status="<%= reg.status %>" data-aos="fade-up">

        <!-- ── Gradient header: participant + status ── -->
        <div class="reg-card-head">
          <div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;">
            <div class="reg-card-num"><%= idx + 1 %></div>
            <div style="min-width:0;">
              <div style="font-family:var(--font-display);font-weight:700;font-size:1rem;color:#fff;line-height:1.2;"><%= reg.participantName %></div>
              <div style="font-size:0.78rem;color:rgba(255,255,255,0.75);margin-top:2px;word-break:break-all;">
                <%= reg.participantEmail %>
                <% if (reg.participantPhone) { %>&nbsp;·&nbsp;<%= reg.participantPhone %><% } %>
              </div>
              <div style="font-size:0.7rem;color:rgba(255,255,255,0.50);margin-top:3px;">
                Registered&nbsp;<%= new Date(reg.createdAt).toLocaleString('en-IN',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
              </div>
            </div>
          </div>
          <% if (reg.status === 'verified') { %>
            <span class="reg-badge reg-badge-verified">✓ Verified</span>
          <% } else if (reg.status === 'rejected') { %>
            <span class="reg-badge reg-badge-rejected">✕ Rejected</span>
          <% } else { %>
            <span class="reg-badge reg-badge-pending">⏳ Pending</span>
          <% } %>
        </div>

        <!-- ── Custom form field responses ── -->
        <% if (subEvent.formFields && subEvent.formFields.length > 0) { %>
          <% var sortedFields = subEvent.formFields.slice().sort(function(a,b){ return a.order - b.order; }); %>
          <% var blockHasData = false; %>
          <% for (var qi = 0; qi < sortedFields.length; qi++) { var qf = sortedFields[qi]; var qr = null; for (var qri = 0; qri < reg.responses.length; qri++) { if (reg.responses[qri].fieldId && reg.responses[qri].fieldId.toString() === qf._id.toString()) { qr = reg.responses[qri]; break; } } var qv = qr ? (Array.isArray(qr.value) ? qr.value.join(', ') : qr.value) : ''; if (qv) blockHasData = true; } %>
          <% if (blockHasData) { %>
            <div class="reg-fields-block">
              <% for (var fi3 = 0; fi3 < sortedFields.length; fi3++) { %>
                <%
                  var ff   = sortedFields[fi3];
                  var fr   = null;
                  for (var fri = 0; fri < reg.responses.length; fri++) {
                    if (reg.responses[fri].fieldId && reg.responses[fri].fieldId.toString() === ff._id.toString()) { fr = reg.responses[fri]; break; }
                  }
                  var fv = fr ? (Array.isArray(fr.value) ? fr.value.join(', ') : fr.value) : '';
                %>
                <% if (fv) { %>
                  <div class="reg-field-row">
                    <div class="reg-field-lbl"><%= ff.label %></div>
                    <div class="reg-field-val">
                      <% if (ff.type === 'file') { %>
                        <a href="<%= fv %>" target="_blank" rel="noopener noreferrer" class="btn-details" style="font-size:0.75rem;padding:4px 10px;">
                          <i class="bi bi-file-earmark"></i> View File
                        </a>
                      <% } else { %>
                        <%= fv %>
                      <% } %>
                    </div>
                  </div>
                <% } %>
              <% } %>
            </div>
          <% } %>
        <% } %>

        <!-- ── Team Members ── -->
        <% if (subEvent.enableTeamMembers && reg.teamMembers && reg.teamMembers.length > 0) { %>
          <div class="reg-members-block">
            <div class="reg-members-title">
              <i class="bi bi-people-fill"></i>&nbsp; Team Members
              <span style="font-size:0.75rem;font-weight:500;color:var(--tx-muted);margin-left:6px;">(<%= reg.teamMembers.length %>)</span>
            </div>
            <div style="display:flex;flex-direction:column;gap:10px;">
              <% for (var mi = 0; mi < reg.teamMembers.length; mi++) { %>
                <%
                  var m     = reg.teamMembers[mi];
                  var isObj = m && typeof m === 'object';
                  var mName = isObj ? (m.name  || '—') : (m || '—');
                  var mMail = isObj ? (m.email || '')  : '';
                  var mTel  = isObj ? (m.phone || '')  : '';
                  var mRsp  = (isObj && m.responses) ? m.responses : [];
                %>
                <div class="member-card">
                  <div class="member-card-hd">
                    <i class="bi bi-person-fill"></i>&nbsp; Member <%= mi + 1 %>
                  </div>
                  <div>
                    <!-- Name -->
                    <div class="reg-field-row member-row">
                      <div class="reg-field-lbl member-lbl">Name</div>
                      <div class="reg-field-val"><strong><%= mName %></strong></div>
                    </div>
                    <% if (mMail) { %>
                      <div class="reg-field-row member-row">
                        <div class="reg-field-lbl member-lbl">Email</div>
                        <div class="reg-field-val"><%= mMail %></div>
                      </div>
                    <% } %>
                    <% if (mTel) { %>
                      <div class="reg-field-row member-row">
                        <div class="reg-field-lbl member-lbl">Phone</div>
                        <div class="reg-field-val"><%= mTel %></div>
                      </div>
                    <% } %>
                    <!-- Member custom fields -->
                    <% for (var mri = 0; mri < mRsp.length; mri++) { %>
                      <%
                        var mr = mRsp[mri];
                        var mf = null;
                        for (var xf = 0; xf < (subEvent.formFields || []).length; xf++) {
                          if (subEvent.formFields[xf]._id.toString() === (mr.fieldId ? mr.fieldId.toString() : '')) { mf = subEvent.formFields[xf]; break; }
                        }
                        var mv = Array.isArray(mr.value) ? mr.value.join(', ') : mr.value;
                      %>
                      <% if (mf && mv) { %>
                        <div class="reg-field-row member-row">
                          <div class="reg-field-lbl member-lbl"><%= mf.label %></div>
                          <div class="reg-field-val"><%= mv %></div>
                        </div>
                      <% } %>
                    <% } %>
                  </div>
                </div>
              <% } %>
            </div>
          </div>
        <% } %>

        <!-- ── Payment screenshot ── -->
        <% if (reg.paymentScreenshot) { %>
          <div class="reg-fields-block" style="padding:14px 18px;">
            <div style="font-size:0.72rem;font-weight:800;text-transform:uppercase;letter-spacing:1px;color:var(--br);margin-bottom:10px;"><i class="bi bi-credit-card"></i>&nbsp; Payment Screenshot</div>
            <a href="<%= reg.paymentScreenshot %>" target="_blank">
              <img src="<%= reg.paymentScreenshot %>" alt="Payment" style="max-width:220px;border-radius:var(--r-md);border:1px solid var(--border-l);box-shadow:var(--sh-sm);transition:transform 0.24s ease;" onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
            </a>
          </div>
        <% } %>

        <!-- ── Action buttons ── -->
        <div class="reg-card-actions">
          <% if (reg.status !== 'verified') { %>
            <form action="/registrations/<%= reg._id %>/verify" method="POST" style="margin:0;">
              <button type="submit" class="reg-action-btn reg-btn-verify">
                <i class="bi bi-check-circle"></i> Verify
              </button>
            </form>
          <% } %>
          <% if (reg.status !== 'pending') { %>
            <form action="/registrations/<%= reg._id %>/pending" method="POST" style="margin:0;">
              <button type="submit" class="reg-action-btn reg-btn-pending">
                <i class="bi bi-clock"></i> Move to Pending
              </button>
            </form>
          <% } %>
          <% if (reg.status !== 'rejected') { %>
            <form action="/registrations/<%= reg._id %>/reject" method="POST"
              onsubmit="return confirm('Reject this registration?')" style="margin:0;">
              <button type="submit" class="reg-action-btn reg-btn-reject">
                <i class="bi bi-x-circle"></i> Reject
              </button>
            </form>
          <% } %>
          <form action="/registrations/<%= reg._id %>/delete" method="POST"
            onsubmit="return confirm('Permanently delete this registration?')"
            style="margin:0;margin-left:auto;">
            <button type="submit" class="reg-action-btn reg-btn-delete">
              <i class="bi bi-trash3"></i> Delete
            </button>
          </form>
        </div>

      </div>
    <% } %>

  </div>

  <div style="text-align:center;padding:20px 0 40px;font-size:0.78rem;color:var(--tx-muted);">
    Auto-refreshing in <span id="countdown2" style="font-weight:700;color:var(--br);">30</span>s
    &nbsp;·&nbsp;
    <a href="#" onclick="location.reload();return false;" style="color:var(--br);font-weight:600;">Refresh now</a>
  </div>

</div>


<style>
@keyframes livePulse {
  0%,100% { box-shadow:0 0 0 2px rgba(39,174,96,0.2); }
  50%     { box-shadow:0 0 0 5px rgba(39,174,96,0); }
}

/* ── Stat cards ── */
.reg-stat-card  { border-radius:var(--r-md);padding:16px 18px;text-align:center; }
.reg-stat-value { font-family:var(--font-display);font-size:2rem;font-weight:700;line-height:1; }
.reg-stat-label { font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--tx-muted);margin-top:5px; }
.reg-stat-total    { background:rgba(166,124,82,0.09); border:1px solid rgba(166,124,82,0.22); }
.reg-stat-total    .reg-stat-value { color:var(--br); }
.reg-stat-verified { background:rgba(39,174,96,0.09);  border:1px solid rgba(39,174,96,0.22); }
.reg-stat-verified .reg-stat-value { color:#27ae60; }
.reg-stat-pending  { background:rgba(241,196,15,0.09); border:1px solid rgba(241,196,15,0.28); }
.reg-stat-pending  .reg-stat-value { color:#b8860b; }
.reg-stat-rejected { background:rgba(192,57,43,0.09);  border:1px solid rgba(192,57,43,0.22); }
.reg-stat-rejected .reg-stat-value { color:#c0392b; }

/* ── Registration card ── */
.registration-card {
  background: var(--cream-alt);
  border: 1px solid var(--border-l);
  border-radius: var(--r-lg);
  overflow: hidden;
  margin-bottom: 20px;
  box-shadow: 0 2px 14px rgba(166,124,82,0.07);
  transition: box-shadow 0.22s;
}
.registration-card:hover { box-shadow: 0 5px 24px rgba(166,124,82,0.12); }

/* Gradient card header */
.reg-card-head {
  background: linear-gradient(135deg, var(--br), var(--br-deep));
  padding: 14px 18px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  flex-wrap: wrap;
}
.reg-card-num {
  width:34px; height:34px; border-radius:50%;
  background:rgba(255,255,255,0.22);
  display:flex; align-items:center; justify-content:center;
  color:#fff; font-family:var(--font-display);
  font-weight:800; font-size:0.85rem; flex-shrink:0;
}

/* Status badges */
.reg-badge { padding:4px 13px;border-radius:var(--r-full);font-size:0.74rem;font-weight:700;flex-shrink:0; }
.reg-badge-verified { background:rgba(39,174,96,0.18); border:1px solid rgba(39,174,96,0.36); color:#27ae60; }
.reg-badge-pending  { background:rgba(241,196,15,0.18); border:1px solid rgba(241,196,15,0.36); color:#b8860b; }
.reg-badge-rejected { background:rgba(192,57,43,0.15); border:1px solid rgba(192,57,43,0.33); color:#c0392b; }

/* Custom fields block */
.reg-fields-block { border-top:1px solid var(--border-l); }
.reg-field-row {
  display:flex; align-items:flex-start; gap:12px;
  padding:9px 18px; flex-wrap:wrap;
  border-bottom:1px solid var(--border-l);
}
.reg-field-row:last-child { border-bottom:none; }
.reg-field-lbl {
  font-size:0.71rem; font-weight:800;
  text-transform:uppercase; letter-spacing:0.8px;
  color:var(--br); flex-shrink:0; width:120px; padding-top:2px;
}
.reg-field-val { font-size:0.88rem; color:var(--tx-mid); flex:1; word-break:break-word; }

/* Team members block */
.reg-members-block {
  border-top: 1px solid var(--border-l);
  padding: 16px 18px 18px;
}
.reg-members-title {
  font-size:0.72rem; font-weight:800;
  text-transform:uppercase; letter-spacing:1.4px;
  color:var(--br); margin-bottom:12px;
  display:flex; align-items:center;
}

/* Member cards */
.member-card {
  border:1.5px solid rgba(166,124,82,0.20);
  border-radius:var(--r-md); overflow:hidden;
  background:var(--cream);
}
.member-card-hd {
  background:linear-gradient(135deg,rgba(166,124,82,0.12),rgba(166,124,82,0.06));
  padding:7px 14px; border-bottom:1px solid rgba(166,124,82,0.16);
  font-size:0.71rem; font-weight:800;
  text-transform:uppercase; letter-spacing:1.2px;
  color:var(--br);
}
.member-row { padding:7px 14px !important; }
.member-lbl { width:80px !important; font-size:0.68rem !important; }

/* Action buttons */
.reg-card-actions {
  border-top:1px solid var(--border-l);
  padding:11px 16px;
  display:flex; gap:8px; flex-wrap:wrap; align-items:center;
  background:rgba(166,124,82,0.025);
}
.reg-action-btn {
  padding:6px 15px; border-radius:var(--r-full);
  border:1px solid transparent; cursor:pointer;
  font-size:0.8rem; font-weight:600;
  transition:all 0.18s ease;
  display:inline-flex; align-items:center; gap:5px;
  font-family:var(--font-body);
}
.reg-btn-verify  { background:rgba(39,174,96,0.09);  border-color:rgba(39,174,96,0.26);  color:#1a7a3e; }
.reg-btn-verify:hover  { background:rgba(39,174,96,0.17); }
.reg-btn-pending { background:rgba(241,196,15,0.09); border-color:rgba(241,196,15,0.28); color:#8a6914; }
.reg-btn-pending:hover { background:rgba(241,196,15,0.17); }
.reg-btn-reject  { background:rgba(192,57,43,0.07);  border-color:rgba(192,57,43,0.22);  color:#c0392b; }
.reg-btn-reject:hover  { background:rgba(192,57,43,0.14); }
.reg-btn-delete  { background:transparent; border-color:rgba(192,57,43,0.16); color:var(--tx-muted); }
.reg-btn-delete:hover  { background:rgba(192,57,43,0.07); color:#c0392b; border-color:rgba(192,57,43,0.30); }

/* dark mode */
body.dark-mode .registration-card  { background:var(--dk-surface);  border-color:var(--border-d); }
body.dark-mode .member-card        { background:var(--dk-elevate);   border-color:var(--border-d); }
body.dark-mode .member-card-hd     { background:rgba(255,255,255,0.06); border-color:var(--border-d); }
body.dark-mode .reg-card-actions   { background:rgba(255,255,255,0.02); border-color:var(--border-d); }
body.dark-mode .reg-fields-block,
body.dark-mode .reg-members-block  { border-color:var(--border-d); }
body.dark-mode .reg-field-row      { border-color:var(--border-d) !important; }
body.dark-mode .reg-field-val      { color:var(--dk-muted); }

/* gallery-empty */
.gallery-empty { text-align:center;padding:40px 20px;background:rgba(166,124,82,0.04);border:1.5px dashed rgba(166,124,82,0.22);border-radius:var(--r-lg); }
.gallery-empty-icon { font-size:2.5rem;margin-bottom:10px;opacity:0.5; }
.gallery-empty p { color:var(--tx-muted);font-size:0.92rem;margin:0; }
</style>


<script>
  // ── Tab filtering ──
  var tabs  = document.querySelectorAll('[data-tab]');
  var cards = document.querySelectorAll('.registration-card');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      tabs.forEach(function(t){ t.classList.remove('active'); });
      tab.classList.add('active');
      var filter  = tab.dataset.tab;
      var visible = 0;
      cards.forEach(function(card){
        var show = filter === 'all' || card.dataset.status === filter;
        card.style.display = show ? 'block' : 'none';
        if (show) visible++;
      });
      var empty = document.getElementById('emptyState');
      if (empty) empty.style.display = visible === 0 ? 'block' : 'none';
    });
  });

  // ── Auto-refresh countdown ──
  var secs  = 30;
  var cdEl  = document.getElementById('countdown');
  var cdEl2 = document.getElementById('countdown2');
  function tick() {
    secs--;
    if (cdEl)  cdEl.textContent  = secs;
    if (cdEl2) cdEl2.textContent = secs;
    if (secs <= 0) { clearInterval(timer); location.reload(); }
  }
  var timer = setInterval(tick, 1000);
  document.addEventListener('focusin',  function(){ clearInterval(timer); if(cdEl) cdEl.textContent='—'; if(cdEl2) cdEl2.textContent='—'; });
  document.addEventListener('focusout', function(){ secs=30; clearInterval(timer); timer=setInterval(tick,1000); });
</script>
