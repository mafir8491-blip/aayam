<!-- views/events/index.ejs -->
<div class="container">

  <!-- Breadcrumbs matching the reference layout -->
  <nav class="events-breadcrumb" data-aos="fade-down">
    <a href="/"><i class="bi bi-house-door-fill"></i> Home</a> / <span>Events</span>
  </nav>

  <div class="page-header" data-aos="fade-down">
    <div class="section-label">Our Events</div>
    <h1 class="page-title">Events</h1>
    <p class="page-subtitle">Select a status below to explore our exciting tech, cultural, sports, and workshop events.</p>
  </div>

  <!-- Admin Add Event unified block -->
  <% if (user && (user.role === "admin" || user.role === "superadmin")) { %>
    <details class="admin-add-form mb-4" data-aos="fade-up" style="background:var(--cream-alt);border:1px solid var(--border-l);border-radius:var(--r-lg);padding:14px;">
      <summary style="cursor:pointer;font-weight:700;color:var(--br);list-style:none;outline:none;padding:4px 0;">
        ➕ Add New Event
      </summary>
      <form action="/events/add" method="POST" enctype="multipart/form-data" class="mt-4" id="addEventForm">
        <div class="row g-2 mb-2">
          <div class="col-md-6">
            <label class="form-label fw-semibold" style="font-size:0.8rem;color:var(--br);">Event Type</label>
            <select name="type" class="form-select mb-2" required>
              <option value="upcoming">Upcoming Event</option>
              <option value="live">Live Event</option>
              <option value="past">Past Event</option>
            </select>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold" style="font-size:0.8rem;color:var(--br);">Category</label>
            <select id="addEventCategory" class="form-select mb-2" required>
              <option value="Technical">Technical</option>
              <option value="Cultural">Cultural</option>
              <option value="Sports">Sports</option>
              <option value="Workshop">Workshop</option>
            </select>
          </div>
        </div>

        <input type="text" name="title" placeholder="Event Title" class="form-control mb-2" required>
        
        <div class="mb-2">
          <label class="form-label fw-semibold" style="font-size:0.8rem;color:var(--br);">Location</label>
          <input type="text" id="addEventLocation" placeholder="Location (e.g. SVNIT Surat)" class="form-control" required>
        </div>

        <!-- Dynamic Custom Details Builder for Add Event -->
        <div class="mb-3">
          <label class="form-label fw-semibold" style="font-size:0.8rem;color:var(--br);">Custom Event Details (optional)</label>
          <div id="addCustomDetailsContainer" style="display:flex;flex-direction:column;gap:10px;margin-bottom:10px;">
          </div>
          <button type="button" class="filter-tab" style="padding:6px 16px;font-size:0.8rem;display:inline-flex;align-items:center;gap:6px;width:auto;" onclick="addCustomDetailRowAddForm()">
            <i class="bi bi-plus-lg"></i> Add Custom Detail
          </button>
        </div>

        <div class="mb-2">
          <label class="form-label fw-semibold" style="font-size:0.8rem;color:var(--br);">Short Description</label>
          <textarea id="addEventActualDesc" placeholder="Enter short summary description" class="form-control" rows="2" required></textarea>
        </div>

        <input type="hidden" name="shortDescription" id="addEventShortDescHidden">

        <textarea name="description" placeholder="Full Description" class="form-control mb-2" required></textarea>
        <textarea name="about" placeholder="About the event (Rich text/HTML)" class="form-control mb-2"></textarea>
        
        <div class="row g-2 mb-2">
          <div class="col-md-6">
            <label class="form-label fw-semibold" style="font-size:0.82rem;color:var(--br);">Start Date</label>
            <input type="date" name="startDate" class="form-control" required>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold" style="font-size:0.82rem;color:var(--br);">End Date</label>
            <input type="date" name="endDate" class="form-control" required>
          </div>
        </div>

        <input type="file" name="bannerImage" class="form-control mb-2" accept="image/*" required>
        <input type="url" name="registrationLink" placeholder="Registration Link (optional, e.g. https://forms.gle/...)" class="form-control mb-3">
        <input type="hidden" name="isPublic" value="true">
        
        <button type="submit" class="btn-register w-100">➕ Add Event</button>
      </form>
    </details>
  <% } %>

  <!-- Status Selection Boxes -->
  <div class="status-selection-container" data-aos="fade-up">
    <div class="status-box" id="box-upcoming" onclick="selectStatus('upcoming')">
      <div class="status-box-icon"><i class="bi bi-calendar2-week"></i></div>
      <div class="status-box-content">
        <h3 class="status-box-title">Upcoming Events</h3>
        <p class="status-box-count"><%= upcomingEvents.length %> Events</p>
      </div>
      <div class="status-box-arrow"><i class="bi bi-chevron-right"></i></div>
    </div>

    <div class="status-box" id="box-live" onclick="selectStatus('live')">
      <div class="status-box-icon live-pulse-icon"><i class="bi bi-play-circle-fill"></i></div>
      <div class="status-box-content">
        <h3 class="status-box-title">Live Events</h3>
        <p class="status-box-count"><%= liveEvents.length %> Events</p>
      </div>
      <div class="status-box-arrow"><i class="bi bi-chevron-right"></i></div>
    </div>

    <div class="status-box" id="box-past" onclick="selectStatus('past')">
      <div class="status-box-icon"><i class="bi bi-check-circle-fill"></i></div>
      <div class="status-box-content">
        <h3 class="status-box-title">Past Events</h3>
        <p class="status-box-count"><%= pastEvents.length %> Events</p>
      </div>
      <div class="status-box-arrow"><i class="bi bi-chevron-right"></i></div>
    </div>
  </div>

  <!-- Category filter tabs (revealed dynamically) -->
  <div id="categoryFilterWrapper" style="display:none; opacity:0; transition:opacity 0.3s ease;">
    <div class="events-filter-bar" style="margin-top: 15px; margin-bottom: 25px;">
      <button class="filter-tab active" data-category="all">All Categories</button>
      <button class="filter-tab" data-category="Technical">Technical</button>
      <button class="filter-tab" data-category="Cultural">Cultural</button>
      <button class="filter-tab" data-category="Sports">Sports</button>
      <button class="filter-tab" data-category="Workshop">Workshop</button>
    </div>
  </div>

  <!-- EJS Local Render Card Helper function -->
  <%
    const renderEventCard = function(event) {
  %>
    <div class="grid-event-card" data-category="<%= event.category %>">
      <!-- Banner image -->
      <a href="/events/<%= event._id %>" class="card-img-wrap">
        <% if (event.bannerImage) { %>
          <img
            src="<%= event.bannerImage %>"
            class="card-img"
            alt="<%= event.title %>"
            onerror="this.src='/images/aayam_img.jpg'"
          >
        <% } else { %>
          <div class="card-img-placeholder"><i class="bi bi-calendar-event"></i></div>
        <% } %>
      </a>

      <div class="card-body-wrap">
        <!-- Category badge -->
        <span class="category-badge"><%= event.category %></span>

        <!-- Title -->
        <h3 class="card-title">
          <a href="/events/<%= event._id %>"><%= event.title %></a>
          <% if (!event.isPublic && user && (user.role === "admin" || user.role === "superadmin")) { %>
            <span class="badge-private">🔒 Private</span>
          <% } %>
        </h3>

        <!-- Details: Date and Location row with icons -->
        <div class="card-info-row">
          <div class="info-item">
            <i class="bi bi-calendar3 info-icon"></i>
            <% 
              const _s = new Date(event.startDate).toLocaleDateString("en-IN", { timeZone: "Asia/Kolkata", day: "numeric", month: "short", year: "numeric" });
            %>
            <span><%= _s %></span>
          </div>
          <div class="info-item">
            <i class="bi bi-geo-alt-fill info-icon"></i>
            <span><%= event.location || 'SVNIT Surat' %></span>
          </div>
        </div>

        <!-- Description summary -->
        <p class="ev-desc-summary" style="font-size:0.85rem;color:var(--tx-muted);line-height:1.5;margin-bottom:15px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
          <%= event.shortDescription %>
        </p>

        <!-- Action buttons -->
        <div class="card-action-btns">
          <a href="/events/<%= event._id %>" class="btn-details-custom">View Details <i class="bi bi-arrow-right"></i></a>
          <% if (event.isPublic) { %>
            <% if (event.hasMainForm && event.mainFormSubId) { %>
              <a href="/register/<%= event.mainFormSubId %>" class="btn-register-custom">Register <i class="bi bi-pencil-square"></i></a>
            <% } else if (event.registrationLink) { %>
              <a href="<%= event.registrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-register-custom">Register <i class="bi bi-box-arrow-up-right"></i></a>
            <% } else { %>
              <a href="/events/<%= event._id %>/register" class="btn-register-custom">Register <i class="bi bi-pencil-square"></i></a>
            <% } %>
          <% } %>
        </div>

        <!-- Admin specific controls -->
        <% if (user && (user.role === "admin" || user.role === "superadmin")) { %>
          <div class="card-admin-row" style="flex-wrap: wrap; gap: 8px;">
            <div style="display:flex; width:100%; gap:4px; margin-bottom: 6px; align-items:center;">
              <span style="font-size:0.7rem; font-weight:700; color:var(--tx-muted); margin-right:4px;">Status:</span>
              <form action="/events/change-status/<%= event._id %>" method="POST" style="margin:0; flex:1;">
                <select name="type" onchange="this.form.submit()" class="form-control-custom" style="font-size:0.75rem; padding:4px 8px; height:auto; border-radius:4px; border:1.5px solid var(--br); background:transparent; color:var(--tx); font-weight:700; cursor:pointer;">
                  <option value="upcoming" <%= event.type === 'upcoming' ? 'selected' : '' %>>Upcoming</option>
                  <option value="live" <%= event.type === 'live' ? 'selected' : '' %>>Live</option>
                  <option value="past" <%= event.type === 'past' ? 'selected' : '' %>>Past</option>
                </select>
              </form>
            </div>
            <a href="/events/edit/<%= event._id %>" class="btn-admin-action">✏ Edit</a>
            <form action="/events/toggle-visibility/<%= event._id %>" method="POST" style="margin:0; flex:1;">
              <button type="submit" class="btn-admin-action btn-warn" style="width:100%;">
                <%= event.isPublic ? '🔒 Private' : '🌐 Public' %>
              </button>
            </form>
            <form action="/events/delete/<%= event._id %>" method="POST" onsubmit="return confirm('Delete this event?')" style="margin:0; flex:1;">
              <button type="submit" class="btn-admin-action btn-danger" style="width:100%;">✕ Delete</button>
            </form>
          </div>
        <% } %>
      </div>
    </div>
  <%
    };
  %>

  <!-- 1. Live Events Section -->
  <div class="event-results-container" id="sec-live">
    <h2 class="section-title-custom">
      <i class="bi bi-play-circle-fill" style="color:#27ae60;"></i> Live Events
    </h2>
    <div class="events-grid">
      <% if (!liveEvents || liveEvents.length === 0) { %>
        <p class="no-events-text">No events are currently live.</p>
      <% } else { %>
        <% liveEvents.forEach(function(event) { %>
          <% renderEventCard(event); %>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- 2. Upcoming Events Section -->
  <div class="event-results-container" id="sec-upcoming">
    <h2 class="section-title-custom">
      <i class="bi bi-calendar2-event-fill" style="color:var(--br);"></i> Upcoming Events
    </h2>
    <div class="events-grid">
      <% if (!upcomingEvents || upcomingEvents.length === 0) { %>
        <p class="no-events-text">No upcoming events scheduled currently.</p>
      <% } else { %>
        <% upcomingEvents.forEach(function(event) { %>
          <% renderEventCard(event); %>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- 3. Past Events Section -->
  <div class="event-results-container" id="sec-past">
    <h2 class="section-title-custom">
      <i class="bi bi-check-circle-fill" style="color:var(--tx-muted);"></i> Past Events
    </h2>
    <div class="events-grid">
      <% if (!pastEvents || pastEvents.length === 0) { %>
        <p class="no-events-text">No past events found.</p>
      <% } else { %>
        <% pastEvents.forEach(function(event) { %>
          <% renderEventCard(event); %>
        <% }); %>
      <% } %>
    </div>
  </div>

</div>

<style>
/* ══════════════════════════════════════
   EVENTS PAGE STATUS OPTIONS & REDESIGN
   ══════════════════════════════════════ */
.events-breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 0.82rem;
  color: var(--tx-muted);
  margin-bottom: 12px;
  font-weight: 600;
}
.events-breadcrumb a {
  text-decoration: none;
  color: var(--br);
  transition: color 0.2s;
}
.events-breadcrumb a:hover {
  color: var(--tx);
}

.status-selection-container {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 20px;
  margin-top: 24px;
  margin-bottom: 36px;
}

.status-box {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 20px 24px;
  border-radius: 16px;
  border: 1.5px solid var(--border-l);
  background: var(--cream-alt);
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  position: relative;
  overflow: hidden;
}

body.dark-mode .status-box {
  border-color: var(--border-d);
  background: var(--dk-surface);
}

.status-box:hover {
  transform: translateY(-4px);
  border-color: var(--br);
  box-shadow: 0 8px 24px rgba(166, 124, 82, 0.12);
}

body.dark-mode .status-box:hover {
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
}

.status-box.active {
  background: linear-gradient(135deg, rgba(166, 124, 82, 0.12), rgba(201, 168, 76, 0.08));
  border-color: var(--br);
  box-shadow: 0 8px 24px rgba(166, 124, 82, 0.15);
}

body.dark-mode .status-box.active {
  background: linear-gradient(135deg, rgba(230, 160, 90, 0.12), rgba(230, 160, 90, 0.05));
  border-color: #e6a05a;
}

.status-box-icon {
  font-size: 1.8rem;
  color: var(--br);
  display: flex;
  align-items: center;
  justify-content: center;
}

body.dark-mode .status-box-icon {
  color: #e6a05a;
}

.live-pulse-icon i {
  color: #27ae60 !important;
  animation: livePulse 1.8s infinite;
}

@keyframes livePulse {
  0% { transform: scale(1); opacity: 0.9; }
  50% { transform: scale(1.1); opacity: 1; }
  100% { transform: scale(1); opacity: 0.9; }
}

.status-box-content {
  flex: 1;
}

.status-box-title {
  font-family: var(--font-display);
  font-size: 1.05rem;
  font-weight: 800;
  color: var(--tx);
  margin: 0 0 4px 0;
}

body.dark-mode .status-box-title {
  color: var(--dk-text);
}

.status-box-count {
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--tx-muted);
  margin: 0;
}

body.dark-mode .status-box-count {
  color: var(--dk-muted);
}

.status-box-arrow {
  font-size: 1rem;
  color: var(--tx-muted);
  opacity: 0.5;
  transition: transform 0.2s ease;
}

.status-box:hover .status-box-arrow {
  transform: translateX(4px);
  opacity: 1;
  color: var(--br);
}

/* Event Results Container styles */
.event-results-container {
  display: none;
  opacity: 0;
  transition: opacity 0.35s ease;
}

.event-results-container.show {
  display: block;
  opacity: 1;
}

.events-filter-bar {
  display: flex;
  justify-content: center;
  gap: 12px;
  flex-wrap: wrap;
  margin-top: 24px;
  margin-bottom: 36px;
}

.filter-tab {
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 600;
  padding: 8px 20px;
  border-radius: 8px;
  border: 1px solid rgba(166, 124, 82, 0.35);
  background: transparent;
  color: var(--tx-muted);
  cursor: pointer;
  transition: all 0.25s ease;
}

body.dark-mode .filter-tab {
  border-color: rgba(230, 160, 90, 0.22);
  color: var(--dk-muted);
}

.filter-tab:hover {
  border-color: var(--br);
  color: var(--br);
  transform: translateY(-1px);
}

.filter-tab.active {
  background: var(--br);
  border-color: var(--br);
  color: #fff !important;
}

.section-title-custom {
  font-family: var(--font-display);
  font-size: 1.5rem;
  font-weight: 800;
  color: var(--tx);
  margin-top: 10px;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
  border-bottom: 2px solid rgba(166, 124, 82, 0.15);
  padding-bottom: 8px;
}

body.dark-mode .section-title-custom {
  color: var(--dk-text);
  border-color: rgba(230, 160, 90, 0.15);
}

.no-events-text {
  font-size: 0.92rem;
  color: var(--tx-muted);
  font-style: italic;
  padding: 14px 18px;
  background: rgba(166, 124, 82, 0.04);
  border-radius: var(--r-md);
  border: 1px dashed var(--border-l);
  margin: 0;
  grid-column: 1 / -1;
}

body.dark-mode .no-events-text {
  background: rgba(230, 160, 90, 0.04);
  border-color: var(--border-d);
}

/* Responsive Grid layout */
.events-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 24px;
  margin-bottom: 28px;
}

.grid-event-card {
  display: flex;
  flex-direction: column;
  border-radius: 16px;
  border: 1px solid var(--border-l);
  background: var(--cream-alt);
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

body.dark-mode .grid-event-card {
  background: var(--dk-surface);
  border-color: var(--border-d);
}

.grid-event-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 10px 25px rgba(166,124,82,0.12);
}

body.dark-mode .grid-event-card:hover {
  box-shadow: 0 10px 25px rgba(0,0,0,0.35);
}

.card-img-wrap {
  display: block;
  width: 100%;
  padding-bottom: 60%; /* 5:3 Aspect Ratio */
  position: relative;
  overflow: hidden;
  background: #06080f;
}

.card-img {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.grid-event-card:hover .card-img {
  transform: scale(1.04);
}

.card-img-placeholder {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  display: flex;
  align-items: center; justify-content: center;
  font-size: 2.2rem;
  color: rgba(166,124,82,0.3);
  background: rgba(166,124,82,0.05);
}

.card-body-wrap {
  padding: 18px;
  display: flex;
  flex-direction: column;
  flex: 1;
}

/* Category Badge capsule */
.category-badge {
  display: inline-block;
  align-self: flex-start;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  padding: 4px 12px;
  border-radius: 4px;
  background: rgba(166, 124, 82, 0.12);
  color: var(--br);
  margin-bottom: 12px;
}

body.dark-mode .category-badge {
  background: rgba(230, 160, 90, 0.12);
  color: #e6a05a;
}

/* Event Title */
.card-title {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 800;
  line-height: 1.35;
  margin: 0 0 10px 0;
}

.card-title a {
  text-decoration: none;
  color: var(--tx);
  transition: color 0.2s;
}

body.dark-mode .card-title a {
  color: var(--dk-text);
}

.card-title a:hover {
  color: var(--br);
}

.badge-private {
  padding: 2px 6px;
  border-radius: var(--r-full);
  background: rgba(192,57,43,0.09);
  border: 1px solid rgba(192,57,43,0.20);
  font-size: 0.62rem;
  font-weight: 700;
  color: #c0392b;
  margin-left: 5px;
}

/* Details info row */
.card-info-row {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 14px;
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--tx-muted);
}

body.dark-mode .card-info-row {
  color: var(--dk-muted);
}

.info-item {
  display: flex;
  align-items: center;
  gap: 6px;
}

.info-icon {
  color: var(--br);
  font-size: 0.85rem;
}

/* Card Button Actions */
.card-action-btns {
  display: flex;
  gap: 8px;
  margin-top: auto;
}

.btn-details-custom {
  flex: 1;
  text-align: center;
  text-decoration: none;
  font-size: 0.8rem;
  font-weight: 700;
  padding: 8px 10px;
  border-radius: 6px;
  border: 1px solid var(--border-l);
  color: var(--tx);
  background: transparent;
  transition: all 0.2s ease;
}

body.dark-mode .btn-details-custom {
  border-color: var(--border-d);
  color: var(--dk-text);
}

.btn-details-custom:hover {
  background: rgba(166, 124, 82, 0.05);
  border-color: var(--br);
  color: var(--br);
}

.btn-register-custom {
  flex: 1;
  text-align: center;
  text-decoration: none;
  font-size: 0.8rem;
  font-weight: 700;
  padding: 8px 10px;
  border-radius: 6px;
  border: 1px solid var(--br);
  color: #fff;
  background: var(--br);
  transition: all 0.2s ease;
}

.btn-register-custom:hover {
  background: transparent;
  color: var(--br);
}

/* Card Admin actions row */
.card-admin-row {
  display: flex;
  gap: 4px;
  margin-top: 14px;
  padding-top: 10px;
  border-top: 1px dashed var(--border-l);
}

body.dark-mode .card-admin-row {
  border-color: var(--border-d);
}

.btn-admin-action {
  flex: 1;
  text-align: center;
  font-size: 0.7rem;
  font-weight: 700;
  padding: 4px;
  border-radius: 4px;
  text-decoration: none;
  background: rgba(166,124,82,0.05);
  border: 1px solid var(--border-l);
  color: var(--tx-muted);
  cursor: pointer;
}

body.dark-mode .btn-admin-action {
  border-color: var(--border-d);
  color: var(--dk-muted);
}

.btn-admin-action:hover {
  border-color: var(--br);
  color: var(--br);
}

.btn-admin-action.btn-warn {
  color: #c0392b;
  border-color: rgba(192, 57, 43, 0.18);
}
.btn-admin-action.btn-warn:hover {
  background: rgba(192, 57, 43, 0.05);
}

.btn-admin-action.btn-danger {
  color: #c0392b;
  border-color: rgba(192, 57, 43, 0.18);
}
.btn-admin-action.btn-danger:hover {
  background: #c0392b;
  color: #fff;
}
</style>

<script>
// Client-side active status tracking
let activeStatus = null;

function selectStatus(status) {
  if (activeStatus === status) return; // Already selected
  activeStatus = status;

  // 1. Highlight the selected box
  document.querySelectorAll('.status-box').forEach(box => box.classList.remove('active'));
  document.getElementById('box-' + status).classList.add('active');

  // 2. Hide all result grids
  document.querySelectorAll('.event-results-container').forEach(sec => {
    sec.classList.remove('show');
    sec.style.display = 'none';
  });

  // 3. Show category filter wrapper
  const filterWrapper = document.getElementById('categoryFilterWrapper');
  if (filterWrapper) {
    filterWrapper.style.display = 'block';
    setTimeout(() => { filterWrapper.style.opacity = '1'; }, 20);
  }

  // 4. Reveal target section
  const targetSec = document.getElementById('sec-' + status);
  if (targetSec) {
    targetSec.style.display = 'block';
    setTimeout(() => {
      targetSec.classList.add('show');
    }, 20);
  }

  // 5. Reset category filtering tab
  const tabs = document.querySelectorAll(".filter-tab");
  tabs.forEach(t => t.classList.remove("active"));
  const allTab = document.querySelector(".filter-tab[data-category='all']");
  if (allTab) allTab.classList.add("active");

  // Show all cards inside the newly revealed section
  const cards = document.querySelectorAll("#sec-" + status + " .grid-event-card");
  cards.forEach(card => {
    card.style.display = "flex";
    card.classList.remove("aos-animate");
    setTimeout(() => card.classList.add("aos-animate"), 20);
  });

  if (typeof AOS !== 'undefined') AOS.refresh();
}

// Dynamic detail rows for Add Event form
function addCustomDetailRowAddForm(key = '', val = '') {
  const container = document.getElementById('addCustomDetailsContainer');
  const div = document.createElement('div');
  div.className = 'custom-detail-row';
  div.style.display = 'flex';
  div.style.gap = '10px';
  div.style.alignItems = 'center';
  div.innerHTML = `
    <input type="text" class="form-control detail-key-input" placeholder="Detail Key (e.g. Fee)" value="${key}" style="flex:1;">
    <input type="text" class="form-control detail-value-input" placeholder="Detail Value (e.g. Free)" value="${val}" style="flex:1;">
    <button type="button" class="btn-admin-action btn-danger" style="flex:0 0 auto;width:40px;height:40px;display:flex;align-items:center;justify-content:center;padding:0;border-radius:6px;" onclick="this.closest('.custom-detail-row').remove()">✕</button>
  `;
  container.appendChild(div);
}

// Client-side filtering script
document.addEventListener("DOMContentLoaded", function() {
  const tabs = document.querySelectorAll(".filter-tab");

  tabs.forEach(tab => {
    tab.addEventListener("click", () => {
      if (!activeStatus) return; // No status selected yet
      
      // Highlight the active tab
      tabs.forEach(t => t.classList.remove("active"));
      tab.classList.add("active");

      const category = tab.getAttribute("data-category");
      const cards = document.querySelectorAll("#sec-" + activeStatus + " .grid-event-card");

      // Filter cards with layout visibility toggle
      cards.forEach(card => {
        const cardCat = card.getAttribute("data-category");
        if (category === "all" || cardCat === category) {
          card.style.display = "flex";
          card.classList.remove("aos-animate");
          setTimeout(() => card.classList.add("aos-animate"), 20);
        } else {
          card.style.display = "none";
        }
      });
      if (typeof AOS !== 'undefined') AOS.refresh();
    });
  });

  // Admin Form Interceptor
  const addForm = document.getElementById("addEventForm");
  if (addForm) {
    addForm.addEventListener("submit", function(e) {
      const category = document.getElementById("addEventCategory").value;
      const location = document.getElementById("addEventLocation").value;
      const desc = document.getElementById("addEventActualDesc").value;
      
      let combined = "Category: " + category + " | Location: " + location;
      
      const rows = document.querySelectorAll('#addCustomDetailsContainer .custom-detail-row');
      rows.forEach(row => {
        const key = row.querySelector('.detail-key-input').value.trim();
        const val = row.querySelector('.detail-value-input').value.trim();
        if (key) {
          combined += " | Detail: " + key + ":" + val;
        }
      });
      
      combined += " | " + desc;
      document.getElementById("addEventShortDescHidden").value = combined;
    });
  }
});
</script>
