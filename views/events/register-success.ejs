<!-- views/events/register-success.ejs -->
<div class="container">
  <div style="max-width:560px; margin:0 auto; padding: clamp(60px,8vw,100px) 0; text-align:center;">

    <!-- Success icon -->
    <div data-aos="zoom-in" style="
      width:100px; height:100px;
      border-radius:50%;
      background: rgba(39,174,96,0.08);
      border: 1.5px solid rgba(39,174,96,0.22);
      display:flex; align-items:center; justify-content:center;
      margin:0 auto 28px;
      box-shadow: 0 0 0 8px rgba(39,174,96,0.04);
    ">
      <div style="
        width: 52px;
        height: 52px;
        background: #27ae60;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 2.2rem;
        box-shadow: 0 6px 16px rgba(39,174,96,0.4);
      ">
        <i class="bi bi-check-lg" style="-webkit-text-stroke: 1px;"></i>
      </div>
    </div>

    <div data-aos="fade-up">
      <div class="section-label" style="margin-bottom:10px;">Registration Complete</div>
      <h1 style="
        font-family: var(--font-display);
        font-size: clamp(1.8rem,5vw,2.6rem);
        font-weight: 900;
        color: var(--tx);
        margin-bottom: 14px;
        letter-spacing: -0.5px;
      ">You're Registered!</h1>

      <p style="
        font-size: clamp(0.95rem,1.5vw,1.05rem);
        color: var(--tx-muted);
        line-height: 1.8;
        margin-bottom: 28px;
        max-width: 440px;
        margin-left: auto;
        margin-right: auto;
      ">
        Your registration for <strong style="color:var(--tx);"><%= subEvent.title %></strong> has been received successfully😁. It will be reviewed shortly,if anything goes wrong we will inform you😊
      </p>
    </div>

    <!-- Details card -->
    <div data-aos="fade-up" data-aos-delay="80" style="
      background: var(--cream-alt);
      border: 1px solid var(--border-l);
      border-radius: var(--r-xl);
      padding: clamp(20px,3vw,32px);
      margin-bottom: 32px;
      text-align: left;
    ">
      <!-- Shimmer top bar -->
      <div style="
        height:3px;
        border-radius:3px 3px 0 0;
        background: linear-gradient(90deg,var(--br-deep),var(--br),var(--gold),var(--br-light),var(--br));
        background-size:200% 100%;
        animation: bandShimmer 4s linear infinite;
        margin:-clamp(20px,3vw,32px) -clamp(20px,3vw,32px) clamp(20px,3vw,32px);
        border-radius: var(--r-md) var(--r-md) 0 0;
      "></div>

      <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--br);margin-bottom:16px;">
        <i class="bi bi-info-circle"></i> Registration Details
      </div>

      <% if (subEvent.eventId) { %>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border-l);">
          <span style="font-size:0.83rem;color:var(--tx-muted);font-weight:600;">Event</span>
          <span style="font-size:0.88rem;color:var(--tx);font-weight:700;text-align:right;max-width:60%;"><%= subEvent.eventId.title %></span>
        </div>
      <% } %>

      <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border-l);">
        <span style="font-size:0.83rem;color:var(--tx-muted);font-weight:600;">Session</span>
        <span style="font-size:0.88rem;color:var(--tx);font-weight:700;text-align:right;max-width:60%;"><%= subEvent.title %></span>
      </div>

      <% if (subEvent.dayNumber || subEvent.startTime) { %>
        <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border-l);">
          <span style="font-size:0.83rem;color:var(--tx-muted);font-weight:600;">Schedule</span>
          <span style="font-size:0.88rem;color:var(--tx);font-weight:700;text-align:right;">
            <% if (subEvent.dayNumber) { %>Day <%= subEvent.dayNumber %><% } %>
            <% if (subEvent.startTime) { %><% if (subEvent.dayNumber) { %> · <% } %><%= subEvent.startTime %><% if (subEvent.endTime) { %> – <%= subEvent.endTime %><% } %><% } %>
          </span>
        </div>
      <% } %>

    <!-- Action buttons -->
    <div data-aos="fade-up" data-aos-delay="160" style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:24px;">
      <% if (subEvent.eventId) { %>
        <a href="/events/<%= subEvent.eventId._id %>" class="btn-details" style="padding: 10px 22px; border: 1.5px solid #a67c52; color: #a67c52; background: transparent; border-radius: 8px; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
          <i class="bi bi-calendar"></i> View Event
        </a>
      <% } %>
      <a href="/events" class="btn-register" style="padding: 10px 22px; background: #5d4037; color: #fff; border-radius: 8px; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; border: none;">
        <i class="bi bi-arrow-left"></i> Back to Events
      </a>
    </div>

  </div>
</div>
</div>
