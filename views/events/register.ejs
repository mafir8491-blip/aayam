<!-- views/events/register.ejs -->
<%
  if (subEvent.externalRegistrationLink && subEvent.externalRegistrationLink.trim() !== '') {
%>
  <script>window.location.replace("<%= subEvent.externalRegistrationLink %>");</script>
  <div class="container" style="text-align:center;padding:80px 20px;">
    <div style="font-size:2rem;margin-bottom:16px;">🔗</div>
    <p style="color:var(--tx-muted);font-size:1rem;">Redirecting to registration form…</p>
    <a href="<%= subEvent.externalRegistrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-register" style="margin-top:16px;display:inline-flex;">
      Click here if not redirected <i class="bi bi-box-arrow-up-right"></i>
    </a>
  </div>
<% } else { %>

<div class="container">

  <!-- Back link -->
  <div style="padding: clamp(18px,2.5vw,30px) 0 0;" data-aos="fade-up">
    <% if (subEvent.eventId) { %>
      <a href="/events/<%= subEvent.eventId._id %>/register" class="btn-details">
        <i class="bi bi-arrow-left"></i> Back to Sessions
      </a>
    <% } %>
  </div>

  <!-- Header -->
  <div class="page-header" data-aos="fade-down">
    <div class="section-label">
      <% if (subEvent.eventId) { %><%= subEvent.eventId.title %><% } %>
    </div>
    <h1 class="page-title"><%= subEvent.title %></h1>
    <% if (subEvent.description) { %>
      <p class="page-subtitle"><%= subEvent.description %></p>
    <% } %>

    <% if (subEvent.startTime || subEvent.eventDate) { %>
      <div style="margin-top:10px;display:inline-flex;align-items:center;gap:8px;padding:6px 16px;background:rgba(166,124,82,0.08);border:1px solid rgba(166,124,82,0.20);border-radius:var(--r-full);">
        <i class="bi bi-clock" style="color:var(--br);"></i>
        <span style="font-size:0.85rem;font-weight:600;color:var(--tx-mid);">
          <% if (subEvent.dayNumber) { %>Day <%= subEvent.dayNumber %> &nbsp;·&nbsp;<% } %>
          <% if (subEvent.eventDate) { %><%= new Date(subEvent.eventDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %><% if (subEvent.startTime) { %> &nbsp;·&nbsp;<% } %><% } %>
          <% if (subEvent.startTime) { %><%= subEvent.startTime %><% if (subEvent.endTime) { %> – <%= subEvent.endTime %><% } %><% } %>
        </span>
      </div>
    <% } %>
  </div>

  <div style="max-width: 620px; margin: 0 auto; padding-bottom: clamp(50px,6vw,90px);">

    <!-- ── Error banners ── -->
    <% if (typeof query !== 'undefined' && query && query.error) { %>
      <%
       const errMsg = query.error === 'full'     ? '⚠ Sorry, registrations for this session are full.'
                     : query.error === 'payment'  ? '⚠ Please upload your payment screenshot.'
                     : query.error === 'deadline' ? '⚠ Registration for this session has closed (deadline passed).'
                     :                              '⚠ Please fill in all required fields.';
      %>
      <div style="background:rgba(192,57,43,0.09);border:1px solid rgba(192,57,43,0.24);border-radius:var(--r-md);padding:14px 18px;margin-bottom:22px;color:#c0392b;font-weight:600;font-size:0.9rem;" data-aos="fade-up">
        <%= errMsg %>
      </div>
    <% } %>

    <!-- ── Capacity indicator ── -->
    <% if (subEvent.maxParticipants) { %>
      <%
        const pct    = Math.min(100, Math.round((subEvent.registrationCount / subEvent.maxParticipants) * 100));
        const isFull = subEvent.registrationCount >= subEvent.maxParticipants;
      %>
      <div style="background:var(--cream-alt);border:1px solid var(--border-l);border-radius:var(--r-md);padding:14px 18px;margin-bottom:22px;" data-aos="fade-up">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;">
          <span style="font-size:0.82rem;font-weight:600;color:var(--tx-mid);">Spots filled</span>
          <span style="font-size:0.82rem;font-weight:700;color:var(--br);"><%= subEvent.registrationCount %>/<%= subEvent.maxParticipants %></span>
        </div>
        <div style="height:6px;border-radius:6px;background:rgba(166,124,82,0.14);overflow:hidden;">
          <div class="<%= isFull ? 'progress-fill-full' : 'progress-fill-normal' %>"
            style="height:100%;width:<%= pct %>%;border-radius:6px;transition:width 0.6s ease;"></div>
        </div>
        <% if (isFull) { %>
          <p style="font-size:0.8rem;color:#c0392b;margin-top:8px;margin-bottom:0;font-weight:600;">This session is full. Registrations are closed.</p>
        <% } %>
      </div>
    <% } %>

    <!-- ── Poster + QR ── -->
    <%
      var hasPoster = subEvent.posterImage && subEvent.posterImage.trim() !== '';
      var hasQR     = subEvent.qrImage     && subEvent.qrImage.trim()     !== '';
    %>
    <% if (hasPoster || hasQR) { %>
      <div class="reg-media-block" data-aos="fade-up">
        <% if (hasPoster) { %>
          <div class="reg-poster-wrap">
            <img src="<%= subEvent.posterImage %>" alt="<%= subEvent.title %> Poster" class="reg-poster-img">
          </div>
        <% } %>
        <% if (hasQR) { %>
          <div class="reg-qr-wrap">
            <div style="font-size:0.7rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--br);margin-bottom:10px;">Payment Instructions</div>
            <p style="font-size:0.88rem;color:var(--tx-muted);margin-bottom:16px;text-align:center;">
              Scan the QR code to complete your payment, then upload the screenshot below.
            </p>
            <div style="display:inline-block;padding:10px;background:#fff;border-radius:var(--r-md);box-shadow:var(--sh-sm);">
              <img src="<%= subEvent.qrImage %>" alt="Payment QR" style="max-width:200px;display:block;">
            </div>
          </div>
        <% } %>
      </div>
    <% } %>

    <!-- ── Registration Form ── -->
    <%
      const isFullFinal = subEvent.maxParticipants && subEvent.registrationCount >= subEvent.maxParticipants;

      // Build list of custom fields that should also repeat per member
      const memberFields = (subEvent.formFields || [])
        .filter(function(f){ return f.askForMembers; })
        .sort(function(a,b){ return a.order - b.order; });
    %>

    <% if (!isFullFinal) { %>

      <div class="form-card" data-aos="fade-up" data-aos-delay="100">
        <form id="registrationForm" action="/register/<%= subEvent._id %>" method="POST" enctype="multipart/form-data" novalidate>

          <!-- ══════════════════════════════
               LEADER / PARTICIPANT DETAILS
          ══════════════════════════════ -->
          <div style="padding:16px;background:rgba(166,124,82,0.05);border:1px solid rgba(166,124,82,0.16);border-radius:var(--r-md);margin-bottom:22px;">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--br);margin-bottom:14px;">
              <i class="bi bi-person-fill"></i>
              <%= subEvent.enableTeamMembers ? 'Team Leader Details' : 'Participant Details' %>
            </div>

            <div class="form-group-custom">
              <label class="form-label-custom" for="participantName">
                Full Name <span style="color:#c0392b;">*</span>
              </label>
              <input type="text" id="participantName" name="participantName" class="form-control-custom"
                placeholder="Enter your full name" value="<%= typeof user !== 'undefined' && user ? user.name : '' %>" required>
            </div>

            <div class="form-group-custom">
              <label class="form-label-custom" for="participantEmail">
                Email Address <span style="color:#c0392b;">*</span>
              </label>
              <input type="email" id="participantEmail" name="participantEmail" class="form-control-custom"
                placeholder="you@example.com" value="<%= typeof user !== 'undefined' && user ? user.email : '' %>" readonly required>
            </div>

            <div class="form-group-custom" style="margin-bottom:0;">
              <label class="form-label-custom" for="participantPhone">
                Phone Number <span style="color:#c0392b;">*</span>
              </label>
              <input type="tel" id="participantPhone" name="participantPhone" class="form-control-custom"
                placeholder="+91 XXXXX XXXXX" required>
            </div>
          </div>

          <!-- ══════════════════════════════
               CUSTOM FORM FIELDS (leader)
          ══════════════════════════════ -->
          <% if (subEvent.formFields && subEvent.formFields.length > 0) { %>
            <% subEvent.formFields.slice().sort((a, b) => a.order - b.order).forEach((field, fi) => { %>
              <div class="form-group-custom" data-aos="fade-up" data-aos-delay="<%= fi * 40 %>">
                <label class="form-label-custom" for="field-<%= field._id %>">
                  <%= field.label %>
                  <% if (field.required) { %><span style="color:#c0392b;margin-left:2px;">*</span><% } %>
                  <% if (field.askForMembers && subEvent.enableTeamMembers) { %>
                    <span style="font-size:0.7rem;font-weight:600;color:var(--br);margin-left:6px;opacity:0.75;">(asked per member too)</span>
                  <% } %>
                </label>

                <% if (field.type === 'text') { %>
                  <input type="text" id="field-<%= field._id %>" name="responses[<%= field._id %>]"
                    class="form-control-custom" placeholder="<%= field.placeholder || '' %>"
                    <%= field.required ? 'required' : '' %>>

                <% } else if (field.type === 'textarea') { %>
                  <textarea id="field-<%= field._id %>" name="responses[<%= field._id %>]"
                    class="form-control-custom" rows="3" placeholder="<%= field.placeholder || '' %>"
                    style="resize:vertical;" <%= field.required ? 'required' : '' %>></textarea>

                <% } else if (field.type === 'dropdown') { %>
                  <select id="field-<%= field._id %>" name="responses[<%= field._id %>]"
                    class="form-control-custom" style="cursor:pointer;" <%= field.required ? 'required' : '' %>>
                    <option value="">— Select an option —</option>
                    <% field.options.forEach(opt => { %>
                      <option value="<%= opt %>"><%= opt %></option>
                    <% }) %>
                  </select>

                <% } else if (field.type === 'checkbox') { %>
                  <div style="display:flex;flex-direction:column;gap:10px;padding:10px 0;">
                    <% field.options.forEach(opt => { %>
                      <label class="checkbox-opt" style="display:flex;align-items:center;gap:10px;cursor:pointer;font-size:0.93rem;color:var(--tx-mid);padding:10px 14px;border-radius:var(--r-sm);border:1.5px solid var(--border-l);background:var(--cream);transition:border-color 0.2s ease,background 0.2s ease;">
                        <input type="checkbox" name="responses[<%= field._id %>][]" value="<%= opt %>"
                          style="width:17px;height:17px;accent-color:var(--br);cursor:pointer;flex-shrink:0;">
                        <%= opt %>
                      </label>
                    <% }) %>
                  </div>

                <% } else if (field.type === 'file') { %>
                  <div style="border:2px dashed rgba(166,124,82,0.32);border-radius:var(--r-md);padding:20px;text-align:center;cursor:pointer;"
                    onclick="document.getElementById('file-<%= field._id %>').click()">
                    <div style="font-size:1.6rem;margin-bottom:6px;opacity:0.5;">📎</div>
                    <div style="font-size:0.85rem;color:var(--tx-muted);">Click to upload file</div>
                    <input type="file" id="file-<%= field._id %>" name="responses[<%= field._id %>]"
                      style="display:none;" <%= field.required ? 'required' : '' %>
                      onchange="showFileName(this)">
                    <div id="filename-<%= field._id %>" style="font-size:0.8rem;color:var(--br);margin-top:6px;font-weight:600;"></div>
                  </div>
                <% } else if (field.type === 'date') { %>
                  <input type="date" id="field-<%= field._id %>" name="responses[<%= field._id %>]"
                    class="form-control-custom" <%= field.required ? 'required' : '' %>>
                <% } else if (field.type === 'time') { %>
                  <input type="time" id="field-<%= field._id %>" name="responses[<%= field._id %>]"
                    class="form-control-custom" <%= field.required ? 'required' : '' %>>
                <% } %>
              </div>
            <% }) %>
          <% } %>

          <!-- ══════════════════════════════
               TEAM MEMBERS (if enabled)
          ══════════════════════════════ -->
          <% if (subEvent.enableTeamMembers) { %>
            <div style="border-top:1px solid var(--border-l);padding-top:22px;margin-top:10px;margin-bottom:22px;">

              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;flex-wrap:wrap;gap:8px;">
                <div class="form-label-custom" style="margin-bottom:0;">
                  <i class="bi bi-people"></i> Team Members
                  <span style="font-weight:400;text-transform:none;letter-spacing:0;font-size:0.78rem;color:var(--tx-muted);margin-left:6px;">
                    (<%= subEvent.minTeamSize %>–<%= subEvent.maxTeamSize %> members)
                  </span>
                </div>
              </div>

              <!-- Member cards injected here by JS -->
              <div id="teamMembersContainer" style="display:flex;flex-direction:column;gap:14px;"></div>

              <button type="button" id="addMemberBtn" class="btn-details" style="margin-top:12px;"
                data-max="<%= subEvent.maxTeamSize %>">
                <i class="bi bi-plus"></i> Add Member
              </button>
              <div id="teamError" style="display:none;font-size:0.82rem;color:#c0392b;margin-top:8px;font-weight:600;">
                Maximum <%= subEvent.maxTeamSize %> members allowed.
              </div>
            </div>
          <% } %>

          <!-- ── Payment Screenshot ── -->
          <% if (subEvent.requirePaymentScreenshot) { %>
            <div class="form-group-custom" style="border-top:1px solid var(--border-l);padding-top:22px;">
              <label class="form-label-custom">
                <i class="bi bi-credit-card"></i> Payment Screenshot
                <span style="color:#c0392b;margin-left:2px;">*</span>
              </label>
              <div id="paymentDropzone"
                style="border:2px dashed rgba(166,124,82,0.32);border-radius:var(--r-md);padding:clamp(22px,3vw,36px) 20px;text-align:center;cursor:pointer;transition:border-color 0.24s ease,background 0.24s ease;background:rgba(166,124,82,0.02);"
                onclick="document.getElementById('paymentInput').click()">
                <div style="font-size:2.2rem;margin-bottom:8px;opacity:0.5;">🧾</div>
                <div style="font-size:0.9rem;color:var(--tx-muted);margin-bottom:4px;">Click to upload screenshot</div>
                <div style="font-size:0.75rem;color:var(--tx-muted);opacity:0.7;">JPG, PNG, WEBP — max 5MB</div>
                <input type="file" id="paymentInput" name="paymentScreenshot" accept="image/*" required
                  style="display:none;" onchange="handlePaymentUpload(this)">
                <div id="paymentPreview" style="margin-top:14px;display:none;">
                  <img id="paymentPreviewImg" src="" alt="Preview"
                    style="max-height:160px;border-radius:var(--r-md);border:1px solid var(--border-l);box-shadow:var(--sh-sm);">
                  <div id="paymentFileName" style="font-size:0.8rem;color:var(--br);margin-top:8px;font-weight:600;"></div>
                </div>
              </div>
            </div>
          <% } %>

          <!-- ── Submit ── -->
          <button type="submit" id="submitBtn" class="btn-register"
            style="width:100%;justify-content:center;padding:14px;font-size:0.97rem;border-radius:var(--r-md);margin-top:8px;">
            <span id="submitText">Submit Registration <i class="bi bi-arrow-right"></i></span>
            <span id="submitSpinner" style="display:none;">
              <span style="display:inline-block;animation:spin 0.7s linear infinite;">⟳</span>
              Submitting...
            </span>
          </button>

        </form>
      </div>

    <% } else { %>
      <div class="gallery-empty" data-aos="fade-up">
        <div class="gallery-empty-icon">🔒</div>
        <p style="color:var(--tx-muted);">Registrations for this session are full.</p>
        <% if (subEvent.eventId) { %>
          <a href="/events/<%= subEvent.eventId._id %>/register" class="btn-details" style="margin-top:16px;">
            ← View Other Sessions
          </a>
        <% } %>
      </div>
    <% } %>

  </div>
</div>

<style>
  @keyframes spin { to { transform: rotate(360deg); } }
  .checkbox-opt:has(input:checked) { border-color: var(--br); background: rgba(166,124,82,0.06); }
  .progress-fill-normal { background: linear-gradient(90deg, var(--br), var(--gold)); }
  .progress-fill-full   { background: linear-gradient(90deg, #c0392b, #e74c3c); }

  .reg-media-block { background: var(--cream-alt); border: 1px solid var(--border-l); border-radius: var(--r-lg); overflow: hidden; margin-bottom: 26px; text-align: center; }
  .reg-poster-wrap { display: flex; justify-content: center; padding: clamp(16px,2.5vw,24px) clamp(16px,2.5vw,24px) 0; }
  .reg-poster-img  { max-width: 420px; width: 100%; border-radius: var(--r-md); box-shadow: var(--sh-sm); display: block; }
  .reg-qr-wrap     { display: flex; flex-direction: column; align-items: center; padding: clamp(18px,2.5vw,28px); border-top: 1px solid var(--border-l); margin-top: clamp(16px,2.5vw,24px); }

  /* ── Member card ── */
  .member-card {
    background: rgba(166,124,82,0.04);
    border: 1.5px solid rgba(166,124,82,0.20);
    border-radius: var(--r-md);
    overflow: hidden;
  }
  .member-card-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 14px;
    background: rgba(166,124,82,0.08);
    border-bottom: 1px solid rgba(166,124,82,0.15);
  }
  .member-card-title { font-size: 0.8rem; font-weight: 700; color: var(--br); text-transform: uppercase; letter-spacing: 1px; }
  .member-card-body  { padding: 14px; display: flex; flex-direction: column; gap: 10px; }
  .member-remove-btn {
    background: none; border: none; cursor: pointer;
    color: var(--tx-muted); font-size: 0.85rem; padding: 2px 6px;
    border-radius: var(--r-sm); transition: color 0.2s;
  }
  .member-remove-btn:hover { color: #c0392b; }

  body.dark-mode .reg-media-block { background: var(--dk-surface); border-color: var(--border-d); }
  body.dark-mode .reg-qr-wrap     { border-color: var(--border-d); }
  body.dark-mode .member-card     { background: rgba(255,255,255,0.03); border-color: var(--border-d); }
  body.dark-mode .member-card-header { background: rgba(255,255,255,0.05); border-color: var(--border-d); }
</style>

<script>
// ── Data passed from server ──
var enableTeamMembers = <%= subEvent.enableTeamMembers ? 'true' : 'false' %>;
var maxTeamSize       = <%= subEvent.maxTeamSize || 1 %>;
var minTeamSize       = <%= subEvent.minTeamSize || 1 %>;

// Custom fields that also apply to each member (only text/textarea/dropdown types make sense for members)
var memberFields = <%- JSON.stringify(
  (subEvent.formFields || [])
    .filter(function(f){ return f.askForMembers && f.type !== 'file'; })
    .sort(function(a,b){ return a.order - b.order; })
    .map(function(f){ return { _id: f._id, label: f.label, type: f.type, placeholder: f.placeholder || '', required: f.required, options: f.options || [] }; })
) %>;

var memberCount   = 0;
var container     = document.getElementById('teamMembersContainer');
var addBtn        = document.getElementById('addMemberBtn');
var teamError     = document.getElementById('teamError');

// ── Build one member card ──
function buildMemberCard(index) {
  memberCount++;
  var card = document.createElement('div');
  card.className = 'member-card';
  card.dataset.memberIndex = index;

  // Header
  var header = document.createElement('div');
  header.className = 'member-card-header';
  header.innerHTML =
    '<span class="member-card-title"><i class="bi bi-person"></i> Member ' + memberCount + '</span>' +
    '<button type="button" class="member-remove-btn" onclick="removeMember(this)"><i class="bi bi-x-lg"></i> Remove</button>';

  // Body
  var body = document.createElement('div');
  body.className = 'member-card-body';

  // Default: Name, Email, Phone
  body.innerHTML +=
    '<div>' +
      '<label style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--br);display:block;margin-bottom:5px;">Full Name <span style="color:#c0392b;">*</span></label>' +
      '<input type="text" name="members[' + index + '][name]" class="form-control-custom" placeholder="Member name" required>' +
    '</div>' +
    '<div>' +
      '<label style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--br);display:block;margin-bottom:5px;">Email Address <span style="color:#c0392b;">*</span></label>' +
      '<input type="email" name="members[' + index + '][email]" class="form-control-custom" placeholder="member@example.com" required>' +
    '</div>' +
    '<div>' +
      '<label style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--br);display:block;margin-bottom:5px;">Phone Number <span style="color:#c0392b;">*</span></label>' +
      '<input type="tel" name="members[' + index + '][phone]" class="form-control-custom" placeholder="+91 XXXXX XXXXX" required>' +
    '</div>';

  // Custom member fields
  memberFields.forEach(function(field) {
    var fieldHtml = '<div><label style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--br);display:block;margin-bottom:5px;">' +
      field.label + (field.required ? ' <span style="color:#c0392b;">*</span>' : '') + '</label>';

    var fieldName = 'members[' + index + '][responses][' + field._id + ']';

    if (field.type === 'text') {
      fieldHtml += '<input type="text" name="' + fieldName + '" class="form-control-custom" placeholder="' + field.placeholder + '"' + (field.required ? ' required' : '') + '>';
    } else if (field.type === 'textarea') {
      fieldHtml += '<textarea name="' + fieldName + '" class="form-control-custom" rows="2" placeholder="' + field.placeholder + '"' + (field.required ? ' required' : '') + ' style="resize:vertical;"></textarea>';
    } else if (field.type === 'dropdown') {
      fieldHtml += '<select name="' + fieldName + '" class="form-control-custom"' + (field.required ? ' required' : '') + '><option value="">— Select —</option>';
      field.options.forEach(function(opt) { fieldHtml += '<option value="' + opt + '">' + opt + '</option>'; });
      fieldHtml += '</select>';
    }
    fieldHtml += '</div>';
    body.innerHTML += fieldHtml;
  });

  card.appendChild(header);
  card.appendChild(body);
  return card;
}

function removeMember(btn) {
  var card = btn.closest('.member-card');
  if (card) card.remove();
  // Recount & re-label
  memberCount = 0;
  container.querySelectorAll('.member-card').forEach(function(c) {
    memberCount++;
    var title = c.querySelector('.member-card-title');
    if (title) title.innerHTML = '<i class="bi bi-person"></i> Member ' + memberCount;
  });
  if (addBtn) addBtn.style.display = 'inline-flex';
  if (teamError) teamError.style.display = 'none';
}

// ── Add member button ──
if (addBtn && container && enableTeamMembers) {
  // Add first member card on load
  container.appendChild(buildMemberCard(0));

  addBtn.addEventListener('click', function() {
    var current = container.querySelectorAll('.member-card').length;
    if (current >= maxTeamSize) {
      if (teamError) teamError.style.display = 'block';
      return;
    }
    if (teamError) teamError.style.display = 'none';
    container.appendChild(buildMemberCard(current));
    if (current + 1 >= maxTeamSize) addBtn.style.display = 'none';
  });
}

// ── File name display ──
function showFileName(input) {
  var id = input.id.replace('file-', 'filename-');
  var el = document.getElementById(id);
  if (el && input.files.length > 0) el.textContent = '✓ ' + input.files[0].name;
}

// ── Payment screenshot preview ──
function handlePaymentUpload(input) {
  if (!input.files || !input.files.length) return;
  var file = input.files[0];
  var reader = new FileReader();
  reader.onload = function(e) {
    document.getElementById('paymentPreviewImg').src = e.target.result;
    document.getElementById('paymentFileName').textContent = '✓ ' + file.name;
    document.getElementById('paymentPreview').style.display = 'block';
    document.getElementById('paymentDropzone').style.borderColor = 'var(--br)';
    document.getElementById('paymentDropzone').style.background = 'rgba(166,124,82,0.04)';
  };
  reader.readAsDataURL(file);
}

// ── Submit spinner ──
var form = document.getElementById('registrationForm');
if (form) {
  form.addEventListener('submit', function() {
    document.getElementById('submitText').style.display    = 'none';
    document.getElementById('submitSpinner').style.display = 'inline';
    document.getElementById('submitBtn').disabled          = true;
    document.getElementById('submitBtn').style.opacity     = '0.8';
  });
}
</script>

<% } %>
