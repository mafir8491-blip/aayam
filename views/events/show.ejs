<!-- views/events/show.ejs -->

<%
function generateTimeOptions(selected) {
  var out = '';
  for (var h = 0; h < 24; h++) {
    for (var m = 0; m < 60; m += 30) {
      var suffix = h < 12 ? 'AM' : 'PM';
      var h12 = h === 0 ? 12 : h > 12 ? h - 12 : h;
      var label = (h12 < 10 ? '0' : '') + h12 + ':' + (m === 0 ? '00' : '30') + ' ' + suffix;
      out += '<option value="' + label + '"' + (label === selected ? ' selected' : '') + '>' + label + '</option>';
    }
  }
  return out;
}
%>
<div class="container my-5">
  <div class="event-detail-content">

    <!-- ══════════════════════════
         POSTER SLIDESHOW
    ══════════════════════════ -->
    <%
      var allSlides = [];
      if (event.bannerImage) allSlides.push(event.bannerImage);
      if (event.posterSlides && event.posterSlides.length > 0) {
        event.posterSlides.forEach(function(s){ allSlides.push(s); });
      }
    %>
    <% if (allSlides.length > 0) { %>
      <div class="slideshow-wrap" data-aos="fade-down">
        <div class="slideshow-track" id="slideshowTrack">
          <% allSlides.forEach(function(slide, si) { %>
            <div class="slide-item" style="display:<%= si === 0 ? 'block' : 'none' %>;">
              <img src="<%= slide %>" alt="<%= event.title %> poster <%= si+1 %>" class="slide-img" loading="<%= si === 0 ? 'eager' : 'lazy' %>">
              <% if (si === 0 && isPast) { %>
                <div style="position:absolute;top:16px;right:16px;">
                  <span class="badge-completed" style="font-size:0.8rem;padding:6px 14px;">Completed</span>
                </div>
              <% } %>
              <% if (si === 0 && event.isPublic === false && user && (user.role === 'admin' || user.role === 'superadmin')) { %>
                <div style="position:absolute;top:16px;left:16px;">
                  <span style="display:inline-flex;align-items:center;gap:5px;padding:4px 12px;border-radius:var(--r-full);background:rgba(0,0,0,0.65);color:#ffd700;font-size:0.72rem;font-weight:700;letter-spacing:1px;border:1px solid rgba(255,215,0,0.35);backdrop-filter:blur(6px);">
                    🔒 Private — Admin View
                  </span>
                </div>
              <% } %>
            </div>
          <% }) %>
        </div>
        <% if (allSlides.length > 1) { %>
          <button class="slide-btn slide-prev" onclick="slideMove(-1)" aria-label="Previous">&#8249;</button>
          <button class="slide-btn slide-next" onclick="slideMove(1)" aria-label="Next">&#8250;</button>
          <div class="slide-dots" id="slideDots">
            <% allSlides.forEach(function(_, si) { %>
              <span class="slide-dot <%= si === 0 ? 'active' : '' %>" onclick="slideTo(<%= si %>)"></span>
            <% }) %>
          </div>
        <% } %>
      </div>
    <% } %>


    <!-- Admin action bar -->
    <% if (user && (user.role === 'admin' || user.role === 'superadmin')) { %>
      <div class="admin-action-bar" data-aos="fade-up">
        <a href="/events/edit/<%= event._id %>" class="btn-details admin-bar-btn">
          <i class="bi bi-pencil-square"></i> Edit Event
        </a>
        <form action="/events/toggle-visibility/<%= event._id %>" method="POST" style="margin:0;flex:1 1 auto;">
          <button type="submit" class="<%= event.isPublic === false ? 'btn-register' : 'btn-admin-warn' %> admin-bar-btn" style="font-size:0.82rem;width:100%;">
            <%= event.isPublic === false ? '🌐 Make Public' : '🔒 Make Private' %>
          </button>
        </form>
      </div>
    <% } %>


    <!-- Title & meta -->
    <div data-aos="fade-up" data-aos-delay="60" style="margin-bottom:28px;">
      <h1 style="font-family:var(--font-display);font-size:clamp(2rem,5vw,3.2rem);font-weight:900;color:var(--tx);line-height:1.12;margin-bottom:14px;letter-spacing:-0.5px;">
        <%= event.title %>
      </h1>
      <% if (event.startDate && event.endDate) { %>
        <div style="display:inline-flex;align-items:center;gap:8px;padding:7px 16px;background:rgba(166,124,82,0.08);border:1px solid rgba(166,124,82,0.2);border-radius:var(--r-full);margin-bottom:20px;">
          <i class="bi bi-calendar3" style="color:var(--br);"></i>
          <span style="font-size:0.88rem;font-weight:600;color:var(--tx-mid);">
            <%
            const _s = new Date(event.startDate).toLocaleDateString('en-IN',{timeZone:'Asia/Kolkata',day:'numeric',month:'long',year:'numeric'});
            const _e = new Date(event.endDate).toLocaleDateString('en-IN',{timeZone:'Asia/Kolkata',day:'numeric',month:'long',year:'numeric'});
          %>
          <%= _s === _e ? _s : _s + ' → ' + _e %>
          </span>
        </div>
      <% } %>
      <% if (event.customDetails && event.customDetails.length > 0) { %>
        <div style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:20px;" data-aos="fade-up" data-aos-delay="80">
          <% event.customDetails.forEach(function(detail) { %>
            <div style="display:inline-flex;align-items:center;gap:6px;padding:7px 16px;background:rgba(166,124,82,0.05);border:1px solid rgba(166,124,82,0.15);border-radius:var(--r-full);">
              <strong style="font-size:0.85rem;color:var(--br);"><%= detail.key %>:</strong>
              <span style="font-size:0.85rem;color:var(--tx-mid);"><%= detail.value %></span>
            </div>
          <% }) %>
        </div>
      <% } %>
      <div class="event-description-body" data-aos="fade-up"><%- event.description %></div>
      <% if (event.about) { %>
        <div style="background:rgba(166,124,82,0.05);border-left:3px solid var(--br);border-radius:0 var(--r-md) var(--r-md) 0;padding:16px 20px;margin-top:18px;max-width:780px;" data-aos="fade-up">
          <div class="event-description-body"><%- event.about %></div>
        </div>
      <% } %>
    </div>

<!-- ══════════════════════════
     SCHEDULE CARDS
══════════════════════════ -->
<% if (event.scheduleCards && event.scheduleCards.length > 0) { %>
  <% var sortedCards = event.scheduleCards.slice().sort(function(a, b) {
       return a.heading.localeCompare(b.heading, undefined, { numeric: true });
     }); %>
  <div class="detail-section" data-aos="fade-up">
    <h2 class="detail-section-title">
      <i class="bi bi-calendar2-week" style="color:var(--br);margin-right:8px;"></i> Event Schedule
    </h2>
    <div class="sched-btn-row">
      <% sortedCards.forEach(function(card, ci) { %>
        <button
          type="button"
          class="sched-pill-btn"
          onclick="openSchedModal('<%= card._id %>')"
          data-aos="fade-up"
          data-aos-delay="<%= ci * 60 %>"
        >
          <i class="bi bi-calendar-week"></i>
          <%= card.heading %>
          <i class="bi bi-chevron-right" style="margin-left:4px;font-size:0.7rem;opacity:0.7;"></i>
        </button>
      <% }) %>
    </div>
  </div>
<% } %>

<!-- Schedule Card Modals -->
<% if (event.scheduleCards && event.scheduleCards.length > 0) { %>
  <% sortedCards.forEach(function(card) { %>
    <div class="sched-modal-overlay" id="sched-modal-<%= card._id %>" onclick="closeSchedModal(event, '<%= card._id %>')">
      <div class="sched-modal-card" role="dialog" aria-modal="true">
        <button class="sched-modal-close" onclick="closeSchedModalById('<%= card._id %>')" aria-label="Close">
          <i class="bi bi-x-lg"></i>
        </button>
        <div class="sched-modal-heading">
          <i class="bi bi-calendar2-week" style="color:var(--br);margin-right:8px;"></i><%= card.heading %>
        </div>
        <% if (card.body && card.body.trim() !== '') { %>
          <div class="sched-modal-body event-description-body"><%- card.body %></div>
        <% } %>
        <% if (card.tableData && card.tableData.columns && card.tableData.columns.length > 0) { %>
          <div class="sched-table-wrap">
            <table class="sched-table">
              <thead>
                <tr>
                  <% card.tableData.columns.forEach(function(col) { %>
                    <th><%= col %></th>
                  <% }) %>
                </tr>
              </thead>
              <tbody>
                <% (card.tableData.rows || []).forEach(function(row) { %>
                  <tr>
                    <% card.tableData.columns.forEach(function(col, ci) { %>
                      <td><%= row[ci] || '' %></td>
                    <% }) %>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
        <% if ((!card.body || card.body.trim() === '') && (!card.tableData || !card.tableData.columns || card.tableData.columns.length === 0)) { %>
          <div class="sched-modal-body"><em style="opacity:0.5;">No details added yet.</em></div>
        <% } %>
      </div>
    </div>
  <% }) %>
<% } %>

<%
  var isAdmin = user && (user.role === 'admin' || user.role === 'superadmin');
  var hasSubEvents = subEvents && subEvents.length > 0;
  var hasExternalLink = event.registrationLink && event.registrationLink.trim() !== '';
  var showRegSection = !isPast || isAdmin;
%>

    <!-- ═══ DOCUMENTS ═══ -->
       <% if ((event.documents && event.documents.length > 0) || isAdmin) { %>
    <div class="detail-section" data-aos="fade-up">
      <h2 class="detail-section-title">Event Brochure</h2>
      <% if (event.documents && event.documents.length > 0) { %>
        <% event.documents.forEach(function(doc, i) { %>
          <% if (doc.isPublic || isAdmin) { %>
            <div class="person-item">
              <div>
                <div class="person-name"><%= doc.title %></div>
                <% if (!doc.isPublic && isAdmin) { %>
                  <span style="font-size:0.72rem;color:#b8860b;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;">Admin Only</span>
                <% } %>
              </div>
              <div style="display:flex;gap:8px;align-items:center;flex-wrap:wrap;">
                <a href="https://docs.google.com/viewer?url=<%= encodeURIComponent(doc.file) %>&embedded=false" target="_blank" rel="noopener noreferrer" class="btn-details" style="font-size:0.82rem;padding:6px 14px;">👁 View</a>
                <% if (isAdmin) { %>
                  <form action="/events/<%= event._id %>/documents/<%= i %>/delete" method="POST" onsubmit="return confirm('Delete?')">
                    <button type="submit" class="btn-admin-danger" style="padding:5px 12px;font-size:0.8rem;">✕</button>
                  </form>
                <% } %>
              </div>
            </div>
          <% } %>
        <% }) %>
      <% } else { %>
        <p style="color:var(--tx-muted);font-size:0.92rem;">No documents uploaded yet.</p>
      <% } %>
      <% if (isAdmin) { %>
        <form action="/events/<%= event._id %>/documents" method="POST" enctype="multipart/form-data" class="admin-add-form mt-3">
          <div class="row g-2">
            <div class="col-md-5"><input type="text" name="title" class="form-control" placeholder="Document title" required></div>
            <div class="col-md-4"><input type="file" name="document" class="form-control" required></div>
            <div class="col-md-3">
              <div class="form-check mb-2"><input class="form-check-input" type="checkbox" name="isPublic" id="isPublicDoc"><label class="form-check-label" for="isPublicDoc" style="font-size:0.82rem;color:var(--tx-muted);">Public</label></div>
              <button type="submit" class="btn-register w-100">Upload</button>
            </div>
          </div>
        </form>
      <% } %>
    </div>
<% } %>

    <!-- ═══ REGISTRATION ═══ -->
    <% if (showRegSection) { %>
      <% if ((mainRegSub || hasExternalLink) && !hasSubEvents) { %>
        <div class="detail-section" data-aos="fade-up">
          <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:18px;padding-bottom:10px;border-bottom:2px solid rgba(166,124,82,0.18);">
            <h2 class="detail-section-title" style="margin-bottom:0;border-bottom:none;padding-bottom:0;">Registration</h2>
            <% if (isAdmin && mainRegSub) { %>
              <div style="display:flex;gap:8px;flex-wrap:wrap;">
                <a href="/admin/subevents/<%= mainRegSub._id %>/registrations"
                  class="btn-details"
                  style="font-size:0.78rem;padding:6px 14px;white-space:nowrap;display:inline-flex;align-items:center;gap:6px;background:rgba(39,174,96,0.08);border-color:rgba(39,174,96,0.30);color:#27ae60;">
                  <i class="bi bi-people"></i> View Registrations
                </a>
                <a href="/admin/subevents/<%= mainRegSub._id %>/registrations/export"
                  class="btn-details"
                  style="font-size:0.78rem;padding:6px 14px;white-space:nowrap;display:inline-flex;align-items:center;gap:6px;background:rgba(39,174,96,0.08);border-color:rgba(39,174,96,0.30);color:#27ae60;">
                  <i class="bi bi-download"></i> Download Registrations
                </a>
              </div>
            <% } %>
          </div>
          <div style="background:linear-gradient(135deg,rgba(166,124,82,0.07),rgba(201,168,76,0.04));border:1.5px solid rgba(166,124,82,0.22);border-radius:var(--r-lg);padding:22px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
            <div>
              <div style="font-family:var(--font-display);font-weight:700;font-size:1rem;color:var(--tx);margin-bottom:4px;">
                <% if (mainRegSub) { %>
                  <i class="bi bi-pencil-square" style="color:var(--br);"></i> Fill Registration Form
                <% } else { %>
                  <i class="bi bi-link-45deg" style="color:var(--br);"></i> Register via External Form
                <% } %>
              </div>
              <div style="font-size:0.82rem;color:var(--tx-muted);"><%= mainRegSub ? 'Fill the form directly on this site' : 'Opens in a new tab' %></div>
            </div>
            <% if (mainRegSub) { %>
              <a href="/register/<%= mainRegSub._id %>" class="btn-register" style="white-space:nowrap;flex-shrink:0;">
                Register Now <i class="bi bi-arrow-right"></i>
              </a>
            <% } else { %>
              <a href="<%= event.registrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-register" style="white-space:nowrap;flex-shrink:0;">
                Register Now <i class="bi bi-box-arrow-up-right"></i>
              </a>
            <% } %>
          </div>
        </div>

      <% } else if (hasSubEvents) { %>
        <div class="detail-section" data-aos="fade-up">

          <div style="display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;margin-bottom:18px;padding-bottom:10px;border-bottom:2px solid rgba(166,124,82,0.18);">
            <h2 class="detail-section-title" style="margin-bottom:0;border-bottom:none;padding-bottom:0;">
              <%= isPast ? 'Sessions & Registrations' : 'Register for Sessions' %>
            </h2>
            <% if (isAdmin) { %>
              <a href="/admin/events/<%= event._id %>/registrations/export-all"
                class="btn-details"
                style="font-size:0.78rem;padding:6px 14px;white-space:nowrap;display:inline-flex;align-items:center;gap:6px;background:rgba(39,174,96,0.08);border-color:rgba(39,174,96,0.30);color:#27ae60;">
                <i class="bi bi-file-earmark-spreadsheet"></i> Export All Registrations CSV
              </a>
            <% } %>
          </div>

          <% if (!isPast && hasExternalLink) { %>
            <div style="display:flex;align-items:center;gap:12px;padding:11px 16px;background:rgba(166,124,82,0.06);border:1px solid rgba(166,124,82,0.18);border-radius:var(--r-md);margin-bottom:16px;flex-wrap:wrap;">
              <div style="flex:1;font-size:0.83rem;font-weight:600;color:var(--tx-mid);"><i class="bi bi-link-45deg" style="color:var(--br);"></i> External registration also available</div>
              <a href="<%= event.registrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-details" style="font-size:0.8rem;padding:6px 14px;white-space:nowrap;flex-shrink:0;">Open Form <i class="bi bi-box-arrow-up-right"></i></a>
            </div>
          <% } %>

          <% if (groupedSubEvents && groupedSubEvents.length > 0) { %>
            <% groupedSubEvents.forEach(function(group) { %>

              <% if (group.day > 0) { %>
                <div style="display:flex;align-items:center;gap:12px;margin:22px 0 12px;" data-aos="fade-up">
                  <div style="padding:4px 16px;background:linear-gradient(135deg,var(--br),var(--br-deep));color:#fff;border-radius:var(--r-full);font-size:0.78rem;font-weight:700;letter-spacing:1px;white-space:nowrap;">
                    DAY <%= group.day %>
                    <% var firstSub = group.subEvents[0]; %>
                   <% if (firstSub && firstSub.eventDate) { %>&nbsp;·&nbsp;<%= new Date(firstSub.eventDate).toLocaleDateString('en-IN',{timeZone:'Asia/Kolkata',day:'numeric',month:'short',year:'numeric'}) %><% } %>
                  </div>
                  <div style="flex:1;height:1px;background:var(--border-l);"></div>
                </div>
              <% } %>

              <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:8px;">
                <% group.subEvents.forEach(function(sub) { %>
                  <%
                    var regOpen = sub.registrationOpen !== false;
                    var isClosed = !regOpen;
                  %>
                  <div class="show-sub-card" data-aos="fade-up" id="show-sub-<%= sub._id %>">

                    <div class="show-sub-top">
                      <div class="show-sub-left">
                        <div class="show-sub-title">
                          <%= sub.title %>
                          <% if (isClosed && !isPast) { %>
                            <span style="font-size:0.68rem;font-weight:700;background:rgba(192,57,43,0.10);color:#c0392b;padding:2px 8px;border-radius:var(--r-full);margin-left:8px;vertical-align:middle;">CLOSED</span>
                          <% } %>
                        </div>
                        <div class="show-sub-pills">
                          <% if (sub.startTime || sub.endTime) { %>
                            <span class="spill spill-time"><i class="bi bi-clock"></i> <%= sub.startTime %><% if (sub.endTime) { %>&thinsp;–&thinsp;<%= sub.endTime %><% } %></span>
                          <% } %>
                          <% if (sub.isGroupEvent) { %>
                            <span class="spill spill-type"><i class="bi bi-people"></i> Team&thinsp;<%= sub.minTeamSize %>–<%= sub.maxTeamSize %></span>
                          <% } else { %>
                            <span class="spill spill-type"><i class="bi bi-person"></i> Individual</span>
                          <% } %>
                          <% if (sub.maxParticipants) { %>
                            <span class="spill spill-cap"><i class="bi bi-person-check"></i> Max&thinsp;<%= sub.maxParticipants %></span>
                          <% } %>
                          <% if (sub.requirePaymentScreenshot) { %>
                            <span class="spill spill-pay"><i class="bi bi-credit-card"></i> Payment req.</span>
                          <% } %>
                          <% if (sub.externalRegistrationLink && sub.externalRegistrationLink.trim() !== '') { %>
                            <span class="spill spill-ext"><i class="bi bi-box-arrow-up-right"></i> External Form</span>
                          <% } %>
                          <% if (sub.registrationDeadline && !isPast) { %>
                            <%
                              var dlDate = new Date(sub.registrationDeadline);
var dlStr  = dlDate.toLocaleDateString('en-IN',{timeZone:'Asia/Kolkata',day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});                            %>
                            <span class="spill <%= isClosed ? 'spill-closed' : 'spill-deadline' %>">
                              <i class="bi bi-alarm"></i>
                              <%= isClosed ? 'Closed' : ('Closes ' + dlStr) %>
                            </span>
                          <% } %>
                        </div>
                      </div>

                      <div class="show-sub-actions">
                        <% if (!isPast) { %>
                          <% if (isClosed) { %>
                            <span class="btn-details" style="opacity:0.5;cursor:not-allowed;font-size:0.85rem;padding:8px 16px;">
                              <i class="bi bi-lock"></i> Closed
                            </span>
                          <% } else if (sub.externalRegistrationLink && sub.externalRegistrationLink.trim() !== '') { %>
                            <a href="<%= sub.externalRegistrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-register" style="white-space:nowrap;font-size:0.85rem;padding:8px 16px;">
                              Register <i class="bi bi-box-arrow-up-right"></i>
                            </a>
                          <% } else { %>
                            <a href="/register/<%= sub._id %>" class="btn-register" style="white-space:nowrap;font-size:0.85rem;padding:8px 16px;">
                              Register <i class="bi bi-arrow-right"></i>
                            </a>
                          <% } %>
                        <% } %>
                        <% if (isAdmin) { %>
                          <a href="/admin/subevents/<%= sub._id %>/registrations" class="btn-details" style="font-size:0.78rem;padding:6px 12px;white-space:nowrap;">
                            <i class="bi bi-people"></i> Registrations
                          </a>
                          <a href="/events/edit/<%= event._id %>#subevent-<%= sub._id %>" class="field-edit-btn" style="font-size:0.72rem;padding:4px 10px;text-decoration:none;">
                            <i class="bi bi-pencil"></i> Edit
                          </a>
                        <% } %>
                      </div>
                    </div>

                    <% if (sub.description) { %>
                      <div class="show-sub-desc"><%= sub.description %></div>
                    <% } %>

                    <% if (sub.posterImage) { %>
                      <div class="show-sub-poster-wrap">
                        <img src="<%= sub.posterImage %>" alt="<%= sub.title %> Poster" class="show-sub-poster-img">
                      </div>
                    <% } %>

                  </div>
                <% }); %>
              </div>
            <% }); %>
          <% } %>

          <% if (!isPast && subEvents.length > 1) { %>
            <div style="margin-top:18px;">
              <a href="/events/<%= event._id %>/register" class="btn-register">Browse All Sessions <i class="bi bi-arrow-right"></i></a>
            </div>
          <% } %>
        </div>

      <% } else if (!isPast) { %>
        <div data-aos="fade-up" style="margin:0 0 30px;">
          <p style="color:var(--tx-muted);font-size:0.93rem;padding:14px 18px;background:rgba(166,124,82,0.05);border-radius:var(--r-md);border:1px solid var(--border-l);margin:0;">
            <i class="bi bi-clock"></i> Registrations will open soon.
          </p>
        </div>
      <% } %>
    <% } %>


    <!-- ═══ SPEAKERS ═══ -->
    <%
      var hasSpeakerImages = event.speakerImages && event.speakerImages.length > 0;
    %>
    <% if (hasSpeakerImages || isAdmin) { %>
      <div class="detail-section" data-aos="fade-up">
        <% if (hasSpeakerImages) { %><h2 class="detail-section-title">Speakers</h2><% } %>
        <% if (hasSpeakerImages) { %>
          <div class="gallery-grid-new">
            <% event.speakerImages.forEach(function(img, i) { %>
              <%
                var hasName   = img.speakerName && img.speakerName.trim() !== '';
                var hasDetail = img.detail && img.detail.trim() !== '';
                var hasCap    = hasName || hasDetail;
              %>
              <div class="gallery-item-new <%= hasCap ? '' : 'no-caption-card' %>" data-aos="fade-up" data-aos-delay="<%= Math.min(i*40,280) %>">
                <div class="gallery-img-wrap">
                  <img src="<%= img.url %>" alt="<%= hasName ? img.speakerName.trim() : ('Speaker '+(i+1)) %>" class="gallery-img-actual" loading="lazy" onerror="this.parentElement.parentElement.style.display='none'">
                  <% if (isAdmin) { %>
                    <form action="/events/<%= event._id %>/speakers/<%= img._id %>/delete" method="POST" style="position:absolute;top:7px;right:7px;margin:0;z-index:2;" onsubmit="return confirm('Remove this speaker image?')">
                      <button type="submit" class="gal-del-btn"><i class="bi bi-x-lg"></i></button>
                    </form>
                  <% } %>
                </div>
                <% if (hasCap) { %>
                  <div class="gallery-caption-below">
                    <% if (hasName) { %><div class="gcap-name"><%= img.speakerName.trim() %></div><% } %>
                    <% if (hasDetail) { %><div class="gcap-detail"><%= img.detail.trim() %></div><% } %>
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
        <% if (isAdmin) { %>
          <form action="/events/<%= event._id %>/speakers" method="POST" enctype="multipart/form-data" class="admin-gallery-upload-form mt-4">
            <div class="section-label" style="margin-bottom:16px;"><i class="bi bi-cloud-upload"></i> Upload Speaker Images</div>
            <div class="gallery-upload-fields">
              <div class="gup-field"><label class="gup-label">Speaker Name (optional)</label><input type="text" name="speakerName" class="form-control-custom" placeholder="e.g. Dr. Raj Mehta"></div>
              <div class="gup-field"><label class="gup-label">Caption / Detail (optional)</label><input type="text" name="detail" class="form-control-custom" placeholder="e.g. Keynote Speaker · AI Workshop"></div>
            </div>
            <div class="gup-file-area" onclick="document.getElementById('speakerFileInput').click()">
              <div class="gup-file-icon">🎤</div><div class="gup-file-label">Click to select speaker images</div><div class="gup-file-hint">JPG, PNG, WEBP · Multiple · Max 30</div>
              <input type="file" id="speakerFileInput" name="speakerImages" multiple accept="image/*" style="display:none;" required onchange="showSpeakerFiles(this)">
              <div id="speakerFileNames" style="margin-top:10px;font-size:0.8rem;color:var(--br);font-weight:600;"></div>
            </div>
            <button type="submit" class="btn-register" style="margin-top:14px;"><i class="bi bi-cloud-upload"></i> Upload Speaker Images</button>
          </form>
        <% } %>
      </div>
    <% } %>


    <!-- ═══ GALLERY ═══ -->
    <%
      var hasGalleryImages = event.galleryImages && event.galleryImages.length > 0;
    %>
    <% if (hasGalleryImages || isAdmin) { %>
      <div class="detail-section" data-aos="fade-up">
        <% if (hasGalleryImages) { %><h2 class="detail-section-title">Event Gallery</h2><% } %>
        <% if (hasGalleryImages) { %>
          <div class="gallery-grid-new">
            <% event.galleryImages.forEach(function(img, i) { %>
              <%
                var hasName   = img.speakerName && img.speakerName.trim() !== '';
                var hasDetail = img.detail && img.detail.trim() !== '';
                var hasCap    = hasName || hasDetail;
              %>
              <div class="gallery-item-new <%= hasCap ? '' : 'no-caption-card' %>" data-aos="fade-up" data-aos-delay="<%= Math.min(i*40,280) %>">
                <div class="gallery-img-wrap">
                  <img src="<%= img.url %>" alt="<%= hasName ? img.speakerName.trim() : ('Gallery '+(i+1)) %>" class="gallery-img-actual" loading="lazy" onerror="this.parentElement.parentElement.style.display='none'">
                  <% if (isAdmin) { %>
                    <form action="/events/<%= event._id %>/gallery/<%= img._id %>/delete" method="POST" style="position:absolute;top:7px;right:7px;margin:0;z-index:2;" onsubmit="return confirm('Remove this image?')">
                      <button type="submit" class="gal-del-btn"><i class="bi bi-x-lg"></i></button>
                    </form>
                  <% } %>
                </div>
                <% if (hasCap) { %>
                  <div class="gallery-caption-below">
                    <% if (hasName) { %><div class="gcap-name"><%= img.speakerName.trim() %></div><% } %>
                    <% if (hasDetail) { %><div class="gcap-detail"><%= img.detail.trim() %></div><% } %>
                  </div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } else if (isAdmin) { %>
          <div class="gallery-empty"><div class="gallery-empty-icon">🖼</div><p>No gallery images yet.</p></div>
        <% } %>
        <% if (isAdmin) { %>
          <form action="/events/<%= event._id %>/gallery" method="POST" enctype="multipart/form-data" class="admin-gallery-upload-form mt-4">
            <div class="section-label" style="margin-bottom:16px;"><i class="bi bi-cloud-upload"></i> Upload Gallery Images</div>
            <div class="gallery-upload-fields">
              <div class="gup-field"><label class="gup-label">Caption Name (optional)</label><input type="text" name="speakerName" class="form-control-custom" placeholder="e.g. Dr. Raj Mehta"></div>
              <div class="gup-field"><label class="gup-label">Detail (optional)</label><input type="text" name="detail" class="form-control-custom" placeholder="e.g. Day 1 · AI Workshop"></div>
            </div>
            <div class="gup-file-area" onclick="document.getElementById('galleryFileInput').click()">
              <div class="gup-file-icon">📷</div><div class="gup-file-label">Click to select images</div><div class="gup-file-hint">JPG, PNG, WEBP · Multiple · Max 30</div>
              <input type="file" id="galleryFileInput" name="galleryImages" multiple accept="image/*" style="display:none;" required onchange="showGalleryFiles(this)">
              <div id="galleryFileNames" style="margin-top:10px;font-size:0.8rem;color:var(--br);font-weight:600;"></div>
            </div>
            <button type="submit" class="btn-register" style="margin-top:14px;"><i class="bi bi-cloud-upload"></i> Upload Images</button>
          </form>
        <% } %>
      </div>
    <% } %>


    <!-- ═══ CONDUCTED BY teachers ═══ -->
      <% if ((event.conductedBy && event.conductedBy.length > 0) || isAdmin) { %>
    <div class="detail-section" data-aos="fade-up">
      <h2 class="detail-section-title">Conducted By Faculty Coordinators</h2>
      <% if (event.conductedBy && event.conductedBy.length > 0) { %>
        <% event.conductedBy.forEach(function(person, i) { %>
          <div class="person-item">
            <div><div class="person-name"><%= person.name %></div><div class="person-email"><%= person.email %></div></div>
            <% if (isAdmin) { %>
              <form action="/events/<%= event._id %>/conducted-by/<%= i %>/delete" method="POST" onsubmit="return confirm('Remove?')">
                <button type="submit" class="btn-admin-danger" style="padding:5px 12px;font-size:0.8rem;">✕</button>
              </form>
            <% } %>
          </div>
        <% }) %>
      <% } else { %>
        <p style="color:var(--tx-muted);font-size:0.92rem;">Coordinator details will be updated.</p>
      <% } %>
      <% if (isAdmin) { %>
        <form action="/events/<%= event._id %>/conducted-by" method="POST" class="admin-add-form mt-3">
          <div class="row g-2">
            <div class="col-md-5"><input type="text" name="name" class="form-control" placeholder="Coordinator name" required></div>
            <div class="col-md-5"><input type="email" name="email" class="form-control" placeholder="Email address" required></div>
            <div class="col-md-2"><button type="submit" class="btn-register w-100">Add</button></div>
          </div>
        </form>
      <% } %>
    </div>
<% } %>
    
  <!-- ═══ CONDUCTED BY students ═══ -->
