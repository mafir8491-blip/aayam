<script>
/* ══════════════════════
   SLIDESHOW
══════════════════════ */
var slideIndex  = 0;
var slideTimer  = null;
var slides      = Array.prototype.slice.call(document.querySelectorAll('.slide-item'));
var dots        = Array.prototype.slice.call(document.querySelectorAll('.slide-dot'));
var slideshowEl = document.querySelector('.slideshow-wrap');

function slideTo(n) {
  if (!slides.length) return;
  slides[slideIndex].style.display = 'none';
  if (dots[slideIndex]) dots[slideIndex].classList.remove('active');
  slideIndex = (n + slides.length) % slides.length;
  slides[slideIndex].style.display = 'block';
  if (dots[slideIndex]) dots[slideIndex].classList.add('active');
}
function slideMove(dir) { slideTo(slideIndex + dir); resetAutoTimer(); }
function startAutoTimer() { if (slides.length <= 1) return; slideTimer = setInterval(function(){ slideTo(slideIndex + 1); }, 5000); }
function resetAutoTimer() { clearInterval(slideTimer); startAutoTimer(); }
function stopAutoTimer() { clearInterval(slideTimer); }

if (slides.length > 0) {
  slides.forEach(function(s, i){ s.style.display = i === 0 ? 'block' : 'none'; });
  startAutoTimer();
}
if (slideshowEl) {
  slideshowEl.addEventListener('mouseenter', stopAutoTimer);
  slideshowEl.addEventListener('mouseleave', startAutoTimer);
}
var touchStartX = 0;
if (slideshowEl) {
  slideshowEl.addEventListener('touchstart', function(e){ touchStartX = e.touches[0].clientX; }, { passive: true });
  slideshowEl.addEventListener('touchend', function(e){
    var diff = touchStartX - e.changedTouches[0].clientX;
    if (Math.abs(diff) > 40) { slideMove(diff > 0 ? 1 : -1); }
  }, { passive: true });
}

/* ══════════════════════
   SCHEDULE MODAL
══════════════════════ */
function openSchedModal(id) {
  var overlay = document.getElementById('sched-modal-' + id);
  if (!overlay) return;
  overlay.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeSchedModalById(id) {
  var overlay = document.getElementById('sched-modal-' + id);
  if (!overlay) return;
  overlay.classList.remove('open');
  document.body.style.overflow = '';
}
function closeSchedModal(e, id) {
  if (e.target === document.getElementById('sched-modal-' + id)) { closeSchedModalById(id); }
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    document.querySelectorAll('.sched-modal-overlay.open').forEach(function(el) { el.classList.remove('open'); });
    document.body.style.overflow = '';
  }
});

/* ══════════════════════
   GALLERY FILE NAMES
══════════════════════ */
function showGalleryFiles(input) {
  var el = document.getElementById('galleryFileNames');
  if (!el || !input.files.length) return;
  el.textContent = '✓ ' + input.files.length + ' file(s): ' + Array.from(input.files).map(function(f){ return f.name; }).join(', ');
  input.closest('.gup-file-area').style.borderColor = 'var(--br)';
}
function showSpeakerFiles(input) {
  var el = document.getElementById('speakerFileNames');
  if (!el || !input.files.length) return;
  el.textContent = '✓ ' + input.files.length + ' file(s): ' + Array.from(input.files).map(function(f){ return f.name; }).join(', ');
  input.closest('.gup-file-area').style.borderColor = 'var(--br)';
}
</script>
