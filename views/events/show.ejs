    <!-- ═══ REVIEWS ═══ -->
    <% if (isPast) { %>
      <div class="detail-section" data-aos="fade-up">
        <h2 class="detail-section-title">⭐ Event Reviews</h2>
        <form action="/events/<%= event._id %>/reviews" method="POST" class="admin-add-form mb-4">
          <div class="row g-2">
            <div class="col-md-4"><input type="text" name="name" class="form-control" placeholder="Your name" required></div>
            <div class="col-md-6"><textarea name="message" class="form-control" placeholder="Write your review..." rows="2" required></textarea></div>
            <div class="col-md-2 d-flex align-items-end"><button type="submit" class="btn-register w-100">Submit</button></div>
          </div>
        </form>
        <% if (!reviews || reviews.length === 0) { %>
          <p style="color:var(--tx-muted);font-size:0.92rem;">No reviews yet. Be the first!</p>
        <% } %>
        <% if (reviews && reviews.length > 0) { %>
          <% reviews.forEach(function(review) { %>
            <div class="review-card" data-aos="fade-up">
              <div class="review-name"><%= review.name %></div>
              <p class="review-body"><%= review.message %></p>
              <% if (isAdmin) { %>
                <form action="/events/<%= event._id %>/reviews/<%= review._id %>/delete" method="POST" class="mt-2" onsubmit="return confirm('Delete review?')">
                  <button type="submit" class="btn-admin-danger" style="padding:5px 12px;font-size:0.8rem;">✕ Delete</button>
                </form>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
    <% } %>

  </div>
</div>


<style>
.event-detail-content { max-width:900px; margin:0 auto; }

.slideshow-wrap {
  position: relative;
  border-radius: var(--r-lg);
  overflow: hidden;
  background: var(--cream-alt, #f5f0e8);
  box-shadow: var(--sh-lg);
  user-select: none;
  width: 100%;
  max-width: 600px;
  margin: 0 auto 32px;
}
body.dark-mode .slideshow-wrap { background: #1a1a1a; }
.slideshow-track { position: relative; width: 100%; }
.slide-item { width: 100%; position: relative; }
.slideshow-track { will-change: contents; }
.slide-img {
  width: 100%;
  height: auto;
  max-height: 520px;
  object-fit: contain;
  object-position: center;
  display: block;
  background: var(--cream-alt, #f5f0e8);
  pointer-events: none;
  -webkit-user-drag: none;
}
body.dark-mode .slide-img { background: #1a1a1a; }
@media (max-width: 768px) { .slideshow-wrap { max-width: 480px; } .slide-img { max-height: 440px; } }
@media (max-width: 576px) { .slideshow-wrap { width: 100%; max-width: 100%; } .slide-img { max-height: 70vw; } }

.slide-btn {
  position: absolute; top: 50%; transform: translateY(-50%);
  background: rgba(0,0,0,0.45); border: none; color: #fff;
  font-size: 2rem; line-height: 1; padding: 6px 14px; cursor: pointer;
  border-radius: var(--r-sm); backdrop-filter: blur(4px); transition: background 0.2s; z-index: 10;
}
.slide-btn:hover { background: rgba(0,0,0,0.72); }
.slide-prev { left: 12px; }
.slide-next { right: 12px; }

.slide-dots {
  position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%);
  display: flex; gap: 7px; z-index: 10;
}
.slide-dot {
  width: 9px; height: 9px; border-radius: 50%;
  background: rgba(255,255,255,0.45); cursor: pointer;
  border: 1.5px solid rgba(255,255,255,0.6); transition: background 0.22s, transform 0.22s;
}
.slide-dot.active { background: var(--br, #8B5E3C); transform: scale(1.25); }

.sched-btn-row { display: flex; flex-wrap: wrap; gap: 10px; }
.sched-pill-btn {
  display: inline-flex; align-items: center; gap: 9px; padding: 11px 22px;
  border-radius: var(--r-full); border: 2px solid rgba(166,124,82,0.35);
  background: rgba(166,124,82,0.08); color: var(--tx);
  font-family: var(--font-display); font-weight: 700; font-size: clamp(0.82rem,1.5vw,0.95rem);
  cursor: pointer;
  transition: background 0.30s cubic-bezier(0.34,1.56,0.64,1), border-color 0.25s ease,
              transform 0.28s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.30s ease, color 0.2s ease;
  will-change: transform;
}
.sched-pill-btn:hover {
  background: rgba(166,124,82,0.16); border-color: var(--br);
  transform: translateY(-3px) scale(1.02); box-shadow: 0 6px 22px rgba(166,124,82,0.22); color: var(--br);
}
.sched-pill-btn:active { transform: translateY(-1px) scale(0.99); }
.sched-pill-btn i { color: var(--br); transition: transform 0.25s ease; }
.sched-pill-btn:hover i.bi-chevron-right { transform: translateX(3px); }
body.dark-mode .sched-pill-btn { border-color:rgba(210,180,140,0.28);background:rgba(210,180,140,0.07);color:var(--dk-text); }
body.dark-mode .sched-pill-btn:hover { background:rgba(210,180,140,0.14);color:#d4b896; }

.sched-modal-overlay {
  display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.52);
  z-index: 9000; align-items: center; justify-content: center; padding: 16px;
  backdrop-filter: blur(5px); -webkit-backdrop-filter: blur(5px);
}
.sched-modal-overlay.open { display: flex; animation: scModalFadeIn 0.22s ease both; }
@keyframes scModalFadeIn { from{opacity:0}to{opacity:1} }
.sched-modal-card {
  background: var(--cream-alt); border-radius: var(--r-xl); max-width: 680px; width: 100%;
  max-height: 88vh; overflow-y: auto; padding: clamp(24px,4vw,40px); position: relative;
  box-shadow: 0 28px 70px rgba(0,0,0,0.22), 0 0 0 1px rgba(166,124,82,0.12);
  animation: scModalSlideUp 0.36s cubic-bezier(0.22,1,0.36,1) both; border-top: 4px solid var(--br);
}
@keyframes scModalSlideUp { from{opacity:0;transform:translateY(40px) scale(0.95)} to{opacity:1;transform:translateY(0) scale(1)} }
.sched-modal-close {
  position: absolute; top: 14px; right: 16px; background: rgba(166,124,82,0.10);
  border: 1px solid var(--border-l); border-radius: 50%; width: 34px; height: 34px;
  display: flex; align-items: center; justify-content: center; cursor: pointer;
  color: var(--tx-muted); transition: background 0.2s, color 0.2s, transform 0.2s; font-size: 0.82rem;
}
.sched-modal-close:hover { background: rgba(192,57,43,0.10); color: #c0392b; transform: scale(1.12); }
.sched-modal-heading { font-family:var(--font-display);font-size:clamp(1.1rem,3vw,1.5rem);font-weight:800;color:var(--tx);margin-bottom:18px;padding-right:30px;line-height:1.3; }
.sched-modal-heading i { color: var(--br) !important; }
.sched-modal-body { font-size:clamp(0.88rem,1.5vw,1rem);color:var(--tx-mid);line-height:1.85; }
.sched-modal-body ul,.sched-modal-body ol { padding-left:20px;margin-bottom:10px; }
.sched-modal-body li { margin-bottom:5px; }
.sched-modal-body h3,.sched-modal-body h4 { font-family:var(--font-display);color:var(--tx);font-weight:700;margin:14px 0 6px; }
body.dark-mode .sched-modal-card { background:var(--dk-surface); }
body.dark-mode .sched-modal-heading { color:var(--dk-text); }
body.dark-mode .sched-modal-body { color:var(--dk-muted); }

.sched-table-wrap { overflow-x:auto;margin-top:16px;border-radius:var(--r-md);border:1px solid rgba(166,124,82,0.25); }
.sched-table { width:100%;border-collapse:collapse;font-size:clamp(0.78rem,1.4vw,0.92rem);min-width:320px; }
.sched-table thead tr { background:linear-gradient(135deg,var(--br),#6b3f1a); }
.sched-table thead th { padding:10px 14px;color:#fff;font-weight:700;text-align:left;white-space:nowrap;border-right:1px solid rgba(255,255,255,0.12); }
.sched-table thead th:last-child { border-right:none; }
.sched-table tbody tr { border-bottom:1px solid rgba(166,124,82,0.12); }
.sched-table tbody tr:nth-child(even) { background:rgba(166,124,82,0.05); }
.sched-table tbody tr:hover { background:rgba(166,124,82,0.10); }
.sched-table tbody td { padding:9px 14px;color:var(--tx-mid);border-right:1px solid rgba(166,124,82,0.08);line-height:1.5; }
.sched-table tbody td:last-child { border-right:none; }
body.dark-mode .sched-table tbody td { color:var(--dk-muted); }
body.dark-mode .sched-table tbody tr:nth-child(even) { background:rgba(255,255,255,0.03); }

.spill-deadline { background:rgba(201,168,76,0.12);border-color:rgba(201,168,76,0.35);color:#8a6914; }
.spill-closed   { background:rgba(192,57,43,0.10);border-color:rgba(192,57,43,0.28);color:#c0392b; }

.event-description-body { font-size:clamp(0.95rem,1.5vw,1.08rem);color:var(--tx-mid);line-height:1.9;max-width:780px; }
.event-description-body p { margin-bottom:14px; }
.event-description-body ul,.event-description-body ol { padding-left:22px;margin-bottom:14px; }
.event-description-body li { margin-bottom:6px; }
.event-description-body h3,.event-description-body h4 { font-family:var(--font-display);color:var(--tx);margin:18px 0 8px;font-weight:700; }
.event-description-body strong { color:var(--tx); }
body.dark-mode .event-description-body { color:var(--dk-muted); }

.detail-section { margin-bottom:38px;padding-bottom:32px; }
.detail-section + .detail-section { border-top:1px solid var(--border-l); padding-top:32px; }
.detail-section-title { font-family:var(--font-display);font-size:1.15rem;font-weight:800;color:var(--tx);margin-bottom:18px;padding-bottom:10px;border-bottom:2px solid rgba(166,124,82,0.18); }

.person-item { display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 16px;background:var(--cream-alt);border:1px solid var(--border-l);border-radius:var(--r-md);margin-bottom:10px;flex-wrap:wrap; }
.person-name { font-weight:700;font-size:0.95rem;color:var(--tx); }
.person-email { font-size:0.8rem;color:var(--tx-muted);margin-top:2px; }

.review-card { background:var(--cream-alt);border:1px solid var(--border-l);border-radius:var(--r-md);padding:16px 18px;margin-bottom:12px; }
.review-name { font-weight:700;font-size:0.9rem;color:var(--br);margin-bottom:6px; }
.review-body { font-size:0.9rem;color:var(--tx-mid);line-height:1.7;margin:0; }

.gallery-empty { text-align:center;padding:40px 20px;background:rgba(166,124,82,0.04);border:1.5px dashed rgba(166,124,82,0.22);border-radius:var(--r-lg);margin-bottom:20px; }
.gallery-empty-icon { font-size:2.5rem;margin-bottom:10px;opacity:0.5; }
.gallery-empty p { color:var(--tx-muted);font-size:0.92rem;margin:0; }
.admin-add-form { background:rgba(166,124,82,0.04);border:1.5px dashed rgba(166,124,82,0.22);border-radius:var(--r-md);padding:18px 20px; }

.show-sub-card { background:var(--cream-alt);border:1px solid var(--border-l);border-radius:var(--r-md);overflow:hidden;transition:border-color 0.22s,box-shadow 0.22s; }
.show-sub-card:hover { border-color:var(--br);box-shadow:0 4px 18px rgba(166,124,82,0.10); }
