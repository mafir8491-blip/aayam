<!-- views/events/subevents.ejs -->
<div class="container" style="max-width:860px;padding-bottom:80px;">


  <!-- Back link -->
  <div style="padding-top:clamp(18px,2.5vw,30px);" data-aos="fade-up">
    <a href="/events/<%= event._id %>" class="btn-details">
      <i class="bi bi-arrow-left"></i> Back to Event
    </a>
  </div>


  <!-- Header -->
  <div class="page-header" data-aos="fade-down">
    <div class="section-label"><%= event.title %></div>
    <h1 class="page-title">Register for a Session</h1>
    <% if (event.startDate && event.endDate) { %>
      <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 16px;background:rgba(166,124,82,0.08);border:1px solid rgba(166,124,82,0.20);border-radius:var(--r-full);margin-top:10px;">
        <i class="bi bi-calendar3" style="color:var(--br);"></i>
        <span style="font-size:0.85rem;font-weight:600;color:var(--tx-mid);">
          <% if (new Date(event.startDate).toDateString() === new Date(event.endDate).toDateString()) { %>
            <%= new Date(event.startDate).toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'}) %>
          <% } else { %>
            <%= new Date(event.startDate).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %> →
            <%= new Date(event.endDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
          <% } %>
        </span>
      </div>
    <% } %>
  </div>


  <!-- ══════════════════════════
       SCHEDULE CARDS
  ══════════════════════════ -->
  <% if (event.scheduleCards && event.scheduleCards.length > 0) { %>
    <div style="margin-bottom:26px;" data-aos="fade-up">
      <div style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--br);margin-bottom:12px;">
        <i class="bi bi-calendar-week"></i> Event Schedule
      </div>
      <div class="sched-btn-row">
        <% event.scheduleCards.forEach(function(card, ci) { %>
          <button
            type="button"
            class="sched-pill-btn"
            onclick="openSchedModal('<%= card._id %>')"
            data-aos="fade-up"
            data-aos-delay="<%= ci * 50 %>"
          >
            <i class="bi bi-calendar-week"></i>
            <%= card.heading %>
            <i class="bi bi-chevron-right" style="margin-left:4px;font-size:0.7rem;opacity:0.7;"></i>
          </button>
        <% }) %>
      </div>
    </div>


    <!-- Schedule Modals -->
    <% event.scheduleCards.forEach(function(card) { %>
      <div class="sched-modal-overlay" id="sched-modal-<%= card._id %>" onclick="closeSchedModal(event, '<%= card._id %>')">
        <div class="sched-modal-card" role="dialog" aria-modal="true">
          <button class="sched-modal-close" onclick="closeSchedModalById('<%= card._id %>')" aria-label="Close">
            <i class="bi bi-x-lg"></i>
          </button>
          <div class="sched-modal-heading"><i class="bi bi-calendar-week" style="color:var(--br);margin-right:8px;"></i><%= card.heading %></div>
          <% if (card.body && card.body.trim() !== '') { %>
            <div class="sched-modal-body event-description-body"><%- card.body %></div>
          <% } %>
          <!-- Table -->
          <% if (card.tableData && card.tableData.columns && card.tableData.columns.length > 0) { %>
            <div class="sched-table-wrap">
              <table class="sched-table">
                <thead>
                  <tr>
                    <% card.tableData.columns.forEach(function(col) { %>
                      <th><%= col %></th>
                    <% }) %>
                  </tr>
                </thead>
                <tbody>
                  <% (card.tableData.rows || []).forEach(function(row) { %>
                    <tr>
                      <% card.tableData.columns.forEach(function(col, ci) { %>
                        <td><%= row[ci] || '' %></td>
                      <% }) %>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          <% } %>
          <% if ((!card.body || card.body.trim() === '') && (!card.tableData || !card.tableData.columns || card.tableData.columns.length === 0)) { %>
            <div class="sched-modal-body"><em style="opacity:0.5;">No details added yet.</em></div>
          <% } %>
        </div>
      </div>
    <% }) %>
  <% } %>


  <!-- External event-level link -->
  <% if (event.registrationLink && event.registrationLink.trim() !== '') { %>
    <div style="display:flex;align-items:center;gap:12px;padding:12px 18px;background:rgba(166,124,82,0.06);border:1px solid rgba(166,124,82,0.20);border-radius:var(--r-md);margin-bottom:22px;flex-wrap:wrap;" data-aos="fade-up">
      <div style="flex:1;font-size:0.85rem;font-weight:600;color:var(--tx-mid);">
        <i class="bi bi-link-45deg" style="color:var(--br);"></i> External registration also available
      </div>
      <a href="<%= event.registrationLink %>" target="_blank" rel="noopener noreferrer" class="btn-details" style="font-size:0.82rem;padding:7px 16px;white-space:nowrap;flex-shrink:0;">
        Open Form <i class="bi bi-box-arrow-up-right"></i>
      </a>
    </div>
  <% } %>


  <!-- No sub-events fallback -->
  <% if (!subEvents || subEvents.length === 0) { %>
    <div class="gallery-empty" data-aos="fade-up">
      <div class="gallery-empty-icon">📅</div>
      <p>No sessions available yet. Check back soon!</p>
    </div>


  <% } else { %>


    <% if (groupedSubEvents && groupedSubEvents.length > 0) { %>
      <% groupedSubEvents.forEach(function(group) { %>


        <!-- Day divider -->
        <% if (group.day > 0) { %>
          <div style="display:flex;align-items:center;gap:12px;margin:28px 0 14px;" data-aos="fade-up">
            <div style="padding:5px 18px;background:linear-gradient(135deg,var(--br),var(--br-deep));color:#fff;border-radius:var(--r-full);font-size:0.78rem;font-weight:700;letter-spacing:1px;white-space:nowrap;">
              DAY <%= group.day %>
              <% var firstSub = group.subEvents[0]; %>
              <% if (firstSub && firstSub.eventDate) { %>
                &nbsp;·&nbsp;<%= new Date(firstSub.eventDate).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %>
              <% } %>
            </div>
            <div style="flex:1;height:1px;background:var(--border-l);"></div>
          </div>
        <% } %>


        <!-- Session cards for this day -->
        <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:10px;">
          <% group.subEvents.forEach(function(sub, si) { %>
            <%
              var isFull    = sub.maxParticipants && sub.registrationCount >= sub.maxParticipants;
              var regOpen   = sub.registrationOpen !== false;
              var isClosed  = !regOpen;
              var hasExternal = sub.externalRegistrationLink && sub.externalRegistrationLink.trim() !== '';
            %>


            <div class="sub-reg-card <%= (isFull || isClosed) ? 'sub-reg-card-full' : '' %>" data-aos="fade-up" data-aos-delay="<%= Math.min(si * 50, 200) %>">


              <div class="sub-reg-top">
                <div class="sub-reg-left">


                  <!-- Title -->
                  <div class="sub-reg-title">
                    <%= sub.title %>
                    <% if (isFull) { %>
                      <span style="font-size:0.7rem;font-weight:700;background:rgba(192,57,43,0.10);color:#c0392b;padding:2px 8px;border-radius:var(--r-full);margin-left:8px;vertical-align:middle;">FULL</span>
                    <% } else if (isClosed) { %>
                      <span style="font-size:0.7rem;font-weight:700;background:rgba(192,57,43,0.10);color:#c0392b;padding:2px 8px;border-radius:var(--r-full);margin-left:8px;vertical-align:middle;">CLOSED</span>
                    <% } %>
                  </div>


                  <!-- Pills -->
                  <div class="show-sub-pills" style="margin-top:8px;">
                    <% if (sub.startTime || sub.endTime) { %>
                      <span class="spill spill-time">
                        <i class="bi bi-clock"></i>
                        <%= sub.startTime %><% if (sub.endTime) { %>&thinsp;–&thinsp;<%= sub.endTime %><% } %>
                      </span>
                    <% } %>
                    <% if (sub.isGroupEvent) { %>
                      <span class="spill spill-type"><i class="bi bi-people"></i> Team&thinsp;<%= sub.minTeamSize %>–<%= sub.maxTeamSize %></span>
                    <% } else { %>
                      <span class="spill spill-type"><i class="bi bi-person"></i> Individual</span>
                    <% } %>
                    <% if (sub.maxParticipants) { %>
                      <span class="spill spill-cap">
                        <i class="bi bi-person-check"></i>&thinsp;<%= sub.registrationCount %>/<%= sub.maxParticipants %> filled
                      </span>
                    <% } %>
                    <% if (sub.requirePaymentScreenshot) { %>
                      <span class="spill spill-pay"><i class="bi bi-credit-card"></i> Payment req.</span>
                    <% } %>
                    <% if (hasExternal) { %>
                      <span class="spill spill-ext"><i class="bi bi-box-arrow-up-right"></i> External Form</span>
                    <% } %>
                    <% if (sub.registrationDeadline) { %>
                      <%
                        var dlDate = new Date(sub.registrationDeadline);
                        var dlStr  = dlDate.toLocaleDateString('en-IN',{day:'numeric',month:'short',hour:'2-digit',minute:'2-digit'});
                      %>
                      <span class="spill <%= isClosed ? 'spill-closed' : 'spill-deadline' %>">
                        <i class="bi bi-alarm"></i>
                        <%= isClosed ? 'Registration Closed' : ('Closes ' + dlStr) %>
                      </span>
                    <% } %>
                  </div>


                  <!-- Description -->
                  <% if (sub.description) { %>
                    <div style="font-size:0.84rem;color:var(--tx-muted);margin-top:10px;line-height:1.6;">
                      <%= sub.description %>
                    </div>
                  <% } %>


                </div>


                <!-- CTA button -->
                <div class="sub-reg-cta">
                  <% if (isFull || isClosed) { %>
                    <span class="btn-details" style="opacity:0.5;cursor:not-allowed;font-size:0.85rem;padding:9px 18px;">
                      <i class="bi bi-lock"></i> <%= isFull ? 'Full' : 'Closed' %>
                    </span>
                  <% } else if (hasExternal) { %>
                    <a href="<%= sub.externalRegistrationLink %>" target="_blank" rel="noopener noreferrer"
                       class="btn-register" style="white-space:nowrap;font-size:0.88rem;padding:10px 20px;">
                      Register <i class="bi bi-box-arrow-up-right"></i>
                    </a>
                  <% } else { %>
                    <a href="/register/<%= sub._id %>"
                       class="btn-register" style="white-space:nowrap;font-size:0.88rem;padding:10px 20px;">
                      Register <i class="bi bi-arrow-right"></i>
                    </a>
                  <% } %>
                </div>
              </div>


              <!-- Capacity bar -->
              <% if (sub.maxParticipants) { %>
                <%
                  var pct = Math.min(100, Math.round((sub.registrationCount / sub.maxParticipants) * 100));
                %>
                <div style="padding:0 clamp(14px,2vw,20px) clamp(12px,1.5vw,16px);">
                  <div style="height:5px;border-radius:5px;background:rgba(166,124,82,0.12);overflow:hidden;">
                    <div style="height:100%;width:<%= pct %>%;border-radius:5px;background:<%= isFull ? 'linear-gradient(90deg,#c0392b,#e74c3c)' : 'linear-gradient(90deg,var(--br),var(--gold))' %>;transition:width 0.5s ease;"></div>
                  </div>
                </div>
              <% } %>


              <!-- FIX: Poster — larger on desktop, contained not stretched -->
              <% if (sub.posterImage) { %>
                <div class="sub-poster-wrap">
                  <img src="<%= sub.posterImage %>" alt="<%= sub.title %> Poster" class="sub-poster-img">
                </div>
              <% } %>


            </div>
          <% }); %>
        </div>


      <% }); %>
    <% } %>


  <% } %>


</div>




<style>
/* Session card */
.sub-reg-card { background:var(--cream-alt);border:1.5px solid var(--border-l);border-radius:var(--r-lg);overflow:hidden;transition:border-color 0.22s,box-shadow 0.22s; }
.sub-reg-card:hover { border-color:var(--br);box-shadow:0 6px 24px rgba(166,124,82,0.12); }
.sub-reg-card-full { opacity:0.75; }
.sub-reg-card-full:hover { border-color:rgba(192,57,43,0.35);box-shadow:0 4px 14px rgba(192,57,43,0.07); }
.sub-reg-top { display:flex;align-items:flex-start;justify-content:space-between;gap:16px;padding:clamp(14px,2vw,20px);flex-wrap:wrap; }
.sub-reg-left { flex:1;min-width:0; }
.sub-reg-title { font-family:var(--font-display);font-weight:700;font-size:clamp(0.98rem,1.8vw,1.1rem);color:var(--tx);line-height:1.3; }
.sub-reg-cta { flex-shrink:0;display:flex;align-items:flex-start; }

/* FIX: Sub-event poster — properly sized on desktop, full image visible */
.sub-poster-wrap {
  display: flex;
  justify-content: center;
  padding: 0 clamp(14px,2vw,20px) clamp(12px,2vw,18px);
  border-top: 1px solid var(--border-l);
  padding-top: clamp(12px,2vw,16px);
}
.sub-poster-img {
  /* FIX: was max-width:320px which was tiny on desktop. Now responsive and big. */
  width: 100%;
  max-width: 500px;
  max-height: 600px;      /* prevent super-tall posters from taking over */
  object-fit: contain;   /* show full image, no crop */
  object-position: center;
  border-radius: var(--r-md);
  border: 1px solid var(--border-l);
  display: block;
  background: var(--cream-alt);
}

/* pills */
.show-sub-pills { display:flex;flex-wrap:wrap;gap:5px; }
.spill { display:inline-flex;align-items:center;gap:3px;padding:3px 9px;border-radius:var(--r-full);font-size:0.71rem;font-weight:700;white-space:nowrap;border:1px solid transparent; }
.spill-time { background:rgba(201,168,76,0.10);border-color:rgba(201,168,76,0.26);color:#8a6914; }
.spill-type,.spill-cap { background:rgba(166,124,82,0.08);border-color:rgba(166,124,82,0.20);color:var(--br); }
.spill-pay,.spill-ext { background:rgba(39,174,96,0.08);border-color:rgba(39,174,96,0.22);color:#27ae60; }
.spill-deadline { background:rgba(201,168,76,0.12);border-color:rgba(201,168,76,0.35);color:#8a6914; }
.spill-closed { background:rgba(192,57,43,0.10);border-color:rgba(192,57,43,0.28);color:#c0392b; }

/* Schedule pills */
.sched-btn-row { display:flex;flex-wrap:wrap;gap:10px; }
.sched-pill-btn {
  display:inline-flex;align-items:center;gap:9px;padding:11px 22px;border-radius:var(--r-full);
  border:2px solid rgba(166,124,82,0.35);background:rgba(166,124,82,0.08);color:var(--tx);
  font-family:var(--font-display);font-weight:700;font-size:clamp(0.82rem,1.5vw,0.95rem);cursor:pointer;
  transition: background 0.30s cubic-bezier(0.34,1.56,0.64,1),
              border-color 0.25s ease,
              transform 0.28s cubic-bezier(0.34,1.56,0.64,1),
              box-shadow 0.30s ease,
              color 0.2s ease;
  will-change: transform;
}
.sched-pill-btn:hover {
  background:rgba(166,124,82,0.16);border-color:var(--br);
  transform:translateY(-3px) scale(1.02);box-shadow:0 6px 22px rgba(166,124,82,0.22);color:var(--br);
}
.sched-pill-btn:active { transform:translateY(-1px) scale(0.99); }
.sched-pill-btn i { color:var(--br);transition:transform 0.25s ease; }
.sched-pill-btn:hover i.bi-chevron-right { transform:translateX(3px); }

/* Schedule modal */
.sched-modal-overlay { display:none;position:fixed;inset:0;background:rgba(0,0,0,0.52);z-index:9000;align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(5px);-webkit-backdrop-filter:blur(5px); }
.sched-modal-overlay.open { display:flex;animation:scModalFadeIn 0.22s ease both; }
@keyframes scModalFadeIn { from{opacity:0} to{opacity:1} }
.sched-modal-card {
  background:var(--cream-alt);border-radius:var(--r-xl);max-width:680px;width:100%;max-height:88vh;overflow-y:auto;
  padding:clamp(24px,4vw,40px);position:relative;
  box-shadow:0 28px 70px rgba(0,0,0,0.22),0 0 0 1px rgba(166,124,82,0.12);
  animation:scModalSlideUp 0.36s cubic-bezier(0.22,1,0.36,1) both;
  border-top:4px solid var(--br);
}
@keyframes scModalSlideUp { from{opacity:0;transform:translateY(40px) scale(0.95)} to{opacity:1;transform:translateY(0) scale(1)} }
.sched-modal-close {
  position:absolute;top:14px;right:16px;background:rgba(166,124,82,0.10);border:1px solid var(--border-l);
  border-radius:50%;width:34px;height:34px;display:flex;align-items:center;justify-content:center;
  cursor:pointer;color:var(--tx-muted);transition:background 0.2s,color 0.2s,transform 0.2s;font-size:0.82rem;
}
.sched-modal-close:hover { background:rgba(192,57,43,0.10);color:#c0392b;transform:scale(1.12); }
.sched-modal-heading { font-family:var(--font-display);font-size:clamp(1.1rem,3vw,1.5rem);font-weight:800;color:var(--tx);margin-bottom:18px;padding-right:30px;line-height:1.3; }
.sched-modal-heading i { color:var(--br) !important; }
.sched-modal-body { font-size:clamp(0.88rem,1.5vw,1rem);color:var(--tx-mid);line-height:1.85; }
.sched-modal-body ul,.sched-modal-body ol { padding-left:20px;margin-bottom:10px; }
.sched-modal-body li { margin-bottom:5px; }
.event-description-body ul,.event-description-body ol { padding-left:20px;margin-bottom:10px; }

/* Table in modal */
.sched-table-wrap { overflow-x:auto;margin-top:16px;border-radius:var(--r-md);border:1px solid rgba(166,124,82,0.25); }
.sched-table { width:100%;border-collapse:collapse;font-size:clamp(0.78rem,1.4vw,0.92rem);min-width:320px; }
.sched-table thead tr { background:linear-gradient(135deg,var(--br),#6b3f1a); }
.sched-table thead th { padding:10px 14px;color:#fff;font-weight:700;text-align:left;white-space:nowrap;border-right:1px solid rgba(255,255,255,0.12); }
.sched-table thead th:last-child { border-right:none; }
.sched-table tbody tr { border-bottom:1px solid rgba(166,124,82,0.12); }
.sched-table tbody tr:nth-child(even) { background:rgba(166,124,82,0.05); }
.sched-table tbody td { padding:9px 14px;color:var(--tx-mid);border-right:1px solid rgba(166,124,82,0.08);line-height:1.5; }
.sched-table tbody td:last-child { border-right:none; }

.gallery-empty { text-align:center;padding:40px 20px;background:rgba(166,124,82,0.04);border:1.5px dashed rgba(166,124,82,0.22);border-radius:var(--r-lg); }
.gallery-empty-icon { font-size:2.5rem;margin-bottom:10px;opacity:0.5; }
.gallery-empty p { color:var(--tx-muted);font-size:0.92rem;margin:0; }

body.dark-mode .sub-reg-card { background:var(--dk-surface);border-color:var(--border-d); }
body.dark-mode .sched-pill-btn { border-color:rgba(210,180,140,0.28);background:rgba(210,180,140,0.07);color:var(--dk-text); }
body.dark-mode .sched-pill-btn:hover { background:rgba(210,180,140,0.14);color:#d4b896; }
body.dark-mode .sched-modal-card { background:var(--dk-surface); }
body.dark-mode .sched-modal-heading { color:var(--dk-text); }
body.dark-mode .sub-poster-img { background:#1a1a1a; }

@media (max-width:576px) {
  .sched-pill-btn { font-size:0.78rem;padding:8px 14px; }
  .sub-reg-top { flex-direction:column; }
  .sub-reg-cta { width:100%; }
  .sub-reg-cta a,.sub-reg-cta span { width:100%;justify-content:center; }
  .sub-poster-img { max-width:100%;max-height:80vw; }
}
</style>




<script>
function openSchedModal(id) {
  var overlay = document.getElementById('sched-modal-' + id);
  if (!overlay) return;
  overlay.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeSchedModalById(id) {
  var overlay = document.getElementById('sched-modal-' + id);
  if (!overlay) return;
  overlay.classList.remove('open');
  document.body.style.overflow = '';
}
function closeSchedModal(e, id) {
  if (e.target === document.getElementById('sched-modal-' + id)) {
    closeSchedModalById(id);
  }
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    document.querySelectorAll('.sched-modal-overlay.open').forEach(function(el){ el.classList.remove('open'); });
    document.body.style.overflow = '';
  }
});
</script>
