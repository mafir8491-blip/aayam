<!-- ══ PROMO BANNER STYLES ══ -->
<style>
/* ────────────────────────────────────────
   HERO PROMO BANNER  — earthy brown palette, no gold
   Base: #3e2723 (dark brown) → #5d4037 (mid brown)
   Accents: var(--br) #a67c52, var(--br-light) #d2b48c
──────────────────────────────────────── */
.hpb-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 12px;
  margin: 24px auto 6px;
  padding: 24px 28px 22px;
  background: linear-gradient(145deg, #3e2723 0%, #5d4037 50%, #3e2723 100%);
  border: 1.5px solid rgba(166, 124, 82, 0.40);
  border-radius: 18px;
  position: relative;
  overflow: hidden;
  box-shadow:
    0 8px 40px rgba(30, 15, 8, 0.50),
    0 0 0 1px rgba(166, 124, 82, 0.12),
    inset 0 1px 0 rgba(255, 255, 255, 0.05);
  width: fit-content;
  max-width: min(580px, 100%);
}
/* Top accent line */
.hpb-wrapper::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, rgba(166, 124, 82, 0.75), transparent);
}
/* Bottom accent line */
.hpb-wrapper::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(166, 124, 82, 0.28), transparent);
}

/* ── 🔥 REGISTER NOW 🔥 row ── */
.hpb-top-row {
  display: flex;
  align-items: center;
  gap: 10px;
}
.hpb-fire {
  font-size: 1.3rem;
  line-height: 1;
}
.hpb-register-heading {
  font-family: var(--font-display, 'Georgia', serif);
  font-size: clamp(1.3rem, 3.5vw, 1.85rem);
  font-weight: 900;
  color: #e8cfa8;
  letter-spacing: 3px;
  text-transform: uppercase;
  text-shadow: 0 2px 10px rgba(0, 0, 0, 0.35);
  line-height: 1;
}

/* ── Sub-heading ── */
.hpb-sub-heading {
  font-family: var(--font-display, 'Georgia', serif);
  font-size: clamp(0.82rem, 1.8vw, 1rem);
  font-weight: 700;
  color: rgba(210, 180, 140, 0.85);
  letter-spacing: 2px;
  text-transform: uppercase;
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
  justify-content: center;
  width: 100%;
}
.hpb-sub-heading::before,
.hpb-sub-heading::after {
  content: '';
  flex: 1;
  min-width: 20px;
  height: 1px;
  background: rgba(166, 124, 82, 0.35);
}

/* ── Event title ── */
.hpb-event-title {
  font-family: var(--font-display, 'Georgia', serif);
  font-size: clamp(1.05rem, 2.5vw, 1.4rem);
  font-weight: 800;
  color: #f0e6d6;
  line-height: 1.2;
  letter-spacing: 0.5px;
}

/* ── Short description ── */
.hpb-event-desc {
  font-size: clamp(0.78rem, 1.5vw, 0.88rem);
  color: rgba(210, 180, 140, 0.70);
  line-height: 1.5;
}

/* ── Countdown ── */
.hpb-countdown-row {
  display: flex;
  align-items: center;
  gap: 6px;
  justify-content: center;
  flex-wrap: wrap;
}
.hpb-cd-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(0, 0, 0, 0.28);
  border: 1.5px solid rgba(166, 124, 82, 0.35);
  border-radius: 10px;
  padding: 8px 14px;
  min-width: 56px;
}
.hpb-cd-num {
  font-family: var(--font-display, 'Georgia', serif);
  font-size: clamp(1.3rem, 3vw, 1.7rem);
  font-weight: 900;
  color: #e8cfa8;
  line-height: 1;
  font-variant-numeric: tabular-nums;
  text-shadow: 0 2px 6px rgba(0, 0, 0, 0.30);
}
.hpb-cd-label {
  font-size: 0.58rem;
  color: rgba(210, 180, 140, 0.60);
  text-transform: uppercase;
  letter-spacing: 1.5px;
  margin-top: 3px;
  font-weight: 700;
}
.hpb-cd-colon {
  font-size: 1.4rem;
  font-weight: 900;
  color: rgba(166, 124, 82, 0.50);
  margin-bottom: 16px;
  line-height: 1;
}

/* ── CTA Button — uses site's existing brown gradient, no gold ── */
.hpb-cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 11px 30px;
  background: linear-gradient(135deg, var(--br, #a67c52), var(--br-deep, #5d4037));
  color: #f0e6d6;
  font-weight: 800;
  font-size: clamp(0.88rem, 2vw, 1rem);
  border-radius: 99px;
  text-decoration: none;
  letter-spacing: 0.5px;
  transition: transform 0.22s, box-shadow 0.22s;
  box-shadow: 0 4px 18px rgba(30, 15, 8, 0.45);
  border: 1.5px solid rgba(166, 124, 82, 0.35);
  font-family: var(--font-display, 'Georgia', serif);
}
.hpb-cta-btn:hover {
  transform: translateY(-2px) scale(1.04);
  box-shadow: 0 8px 28px rgba(30, 15, 8, 0.55);
  color: #fff;
  text-decoration: none;
}

@media (max-width: 600px) {
  .hpb-wrapper { padding: 18px 16px; gap: 10px; }
  .hpb-cd-block { min-width: 46px; padding: 6px 10px; }
  .hpb-register-heading { letter-spacing: 2px; }
  .hpb-sub-heading { font-size: 0.75rem; letter-spacing: 1.2px; }
  .hpb-sub-heading::before, .hpb-sub-heading::after { min-width: 12px; }
}

/* ── Admin promo section ── */
.hs-promo-admin { padding: 28px 0 0; }
.promo-admin-card {
  background: var(--cream-alt);
  border: 1.5px solid rgba(166,124,82,0.30);
  border-radius: var(--r-lg);
