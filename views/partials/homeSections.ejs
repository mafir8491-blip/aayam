<!-- ══ FILE SELECT PREVIEW SCRIPT ══ -->
<script>
function handleFileSelect(input, iconId, textId, previewId) {
  var file = input.files[0];
  if (!file) return;
  var previewBox  = document.getElementById(previewId);
  var previewImg  = document.getElementById(previewId + 'Img');
  var previewName = document.getElementById(previewId + 'Name');
  var iconEl      = document.getElementById(iconId);
  var textEl      = document.getElementById(textId);
  var reader      = new FileReader();
  reader.onload   = function(e) { previewImg.src = e.target.result; };
  reader.readAsDataURL(file);
  previewName.textContent  = file.name;
  iconEl.textContent       = '✅';
  textEl.innerHTML         = '<span class="upload-browse">Change file</span>';
  previewBox.style.display = 'flex';
}
function clearFileSelect(inputId, iconId, textId, previewId) {
  var input      = document.getElementById(inputId);
  var previewBox = document.getElementById(previewId);
  var iconEl     = document.getElementById(iconId);
  var textEl     = document.getElementById(textId);
  input.value              = '';
  previewBox.style.display = 'none';
  iconEl.textContent       = '📁';
  var isEvent = (inputId === 'evtFile');
  textEl.innerHTML = isEvent
    ? 'Drop an event image or <span class="upload-browse">browse</span>'
    : 'Drop an activity image or <span class="upload-browse">browse</span>';
}
</script>


<!-- ══ COUNTDOWN SCRIPT ══ -->
<script>
(function() {
  var cdEl   = document.getElementById('heroCountdown');
  var banner = document.getElementById('heroPromoBanner');
  if (!cdEl || !banner) return;

  var target = new Date(cdEl.getAttribute('data-target')).getTime();

  function pad(n) { return n < 10 ? '0' + n : '' + n; }

  function tick() {
    var now  = Date.now();
    var diff = target - now;

    if (diff <= 0) {
      banner.style.transition = 'opacity 0.8s ease, transform 0.8s ease';
      banner.style.opacity    = '0';
      banner.style.transform  = 'translateY(-12px)';
      setTimeout(function() { banner.style.display = 'none'; }, 850);
      return;
    }

    var days  = Math.floor(diff / 86400000);
    var hours = Math.floor((diff % 86400000) / 3600000);
    var mins  = Math.floor((diff % 3600000)  / 60000);
    var secs  = Math.floor((diff % 60000)    / 1000);

    var dEl = document.getElementById('hcd-days');
    var hEl = document.getElementById('hcd-hours');
    var mEl = document.getElementById('hcd-mins');
    var sEl = document.getElementById('hcd-secs');

    if (dEl) dEl.textContent = pad(days);
    if (hEl) hEl.textContent = pad(hours);
    if (mEl) mEl.textContent = pad(mins);
    if (sEl) sEl.textContent = pad(secs);

    setTimeout(tick, 1000);
  }

  tick();
})();
</script>
