<!-- partials/homeSections.ejs -->
<div class="home-wrapper">


  <!-- ══ HERO ══ -->
  <!-- ══ HERO ══ -->
  <section class="hs-hero" style="background: linear-gradient(rgba(18, 12, 8, 0.78), rgba(18, 12, 8, 0.78)), url('/images/committee_hero.jpg') no-repeat center center; background-size: cover; min-height: 100vh; display: flex; align-items: center; justify-content: center; position: relative; padding-top: clamp(80px, 12vh, 140px) !important; padding-bottom: clamp(60px, 9vh, 100px) !important;">
    <div class="hero-grain" aria-hidden="true"></div>

    <div class="container hs-hero-inner" style="text-align: center;">

      <div style="font-family: var(--font-display, 'Georgia', serif); font-size: clamp(1.3rem, 3.5vw, 2.2rem); color: #fff; font-weight: 400; margin-bottom: 12px; letter-spacing: 0.5px;" data-aos="fade-down" data-aos-delay="100">
        Welcome to
      </div>
      
      <h1 style="font-family: var(--font-display, 'Georgia', serif); font-size: clamp(2.4rem, 7.5vw, 6rem); font-weight: 700; text-transform: uppercase; letter-spacing: 2px; color: #a67c52; margin-bottom: 18px; line-height: 1.1;" data-aos="fade-up" data-aos-delay="200">
        AAYAM COMMITTEE
      </h1>
      
      <div style="font-size: clamp(1.1rem, 3vw, 2.1rem); font-weight: 700; color: #fff; letter-spacing: 0.5px; margin-bottom: 18px;" data-aos="fade-up" data-aos-delay="300">
        Shaping Ideas. Building Tomorrow.
      </div>
      
      <p style="font-size: clamp(0.85rem, 1.8vw, 1.05rem); color: rgba(255,255,255,0.78); max-width: 680px; margin: 0 auto clamp(26px, 4vw, 42px); line-height: 1.7; font-weight: 400;" data-aos="fade-up" data-aos-delay="400">
        AAYAM Committee is the official student body of Sardar Vallabhbhai National Institute of Technology, Surat. We organize, manage and execute technical, cultural and creative events.
      </p>

      <div class="hero-cta-row" data-aos="fade-up" data-aos-delay="500" style="display: flex; gap: 16px; justify-content: center; margin-bottom: clamp(30px, 5vw, 52px); flex-wrap: wrap;">
        <a href="/events" class="hero-cta-primary" style="background: #a67c52; color: #120c08; font-weight: 700; border: none; padding: 12px 28px; border-radius: 8px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; font-size: 0.95rem; box-shadow: 0 6px 18px rgba(166,124,82,0.3); transition: transform 0.3s ease, background 0.3s ease;">
          <span>Explore Events</span>
          <i class="bi bi-arrow-right"></i>
        </a>
        <a href="/#about" class="hero-cta-secondary" style="border: 1.5px solid #a67c52; color: #a67c52; background: transparent; font-weight: 700; padding: 11px 28px; border-radius: 8px; text-decoration: none; display: inline-flex; align-items: center; gap: 8px; font-size: 0.95rem; transition: transform 0.3s ease, border-color 0.3s ease;">
          <span>Learn More</span>
          <i class="bi bi-arrow-right"></i>
        </a>
      </div>

      <div class="hero-stats" data-aos="fade-up" data-aos-delay="600" style="background: rgba(18, 12, 8, 0.70); border: 1.5px solid rgba(166, 124, 82, 0.35); border-radius: 18px; padding: 22px 30px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; max-width: 820px; margin: 0 auto; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);">
        <!-- Stat 1 -->
        <div style="display: flex; align-items: center; gap: 16px; justify-content: center; text-align: left;">
          <div style="font-size: 2.2rem; color: #a67c52; line-height: 1; display: flex; align-items: center;"><i class="bi bi-people-fill"></i></div>
          <div>
            <div style="font-size: 1.6rem; font-weight: 800; color: #fff; line-height: 1.2;">40+</div>
            <div style="font-size: 0.72rem; font-weight: 600; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px;">Team Members</div>
          </div>
        </div>
        <!-- Stat 2 -->
        <div style="display: flex; align-items: center; gap: 16px; justify-content: center; text-align: left; border-left: 1px solid rgba(255,255,255,0.1); padding-left: 12px;">
          <div style="font-size: 2.2rem; color: #a67c52; line-height: 1; display: flex; align-items: center;"><i class="bi bi-calendar-check-fill"></i></div>
          <div>
            <div style="font-size: 1.6rem; font-weight: 800; color: #fff; line-height: 1.2;">25+</div>
            <div style="font-size: 0.72rem; font-weight: 600; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px;">Events Organized</div>
          </div>
        </div>
        <!-- Stat 3 -->
        <div style="display: flex; align-items: center; gap: 16px; justify-content: center; text-align: left; border-left: 1px solid rgba(255,255,255,0.1); padding-left: 12px;">
          <div style="font-size: 2.2rem; color: #a67c52; line-height: 1; display: flex; align-items: center;"><i class="bi bi-trophy-fill"></i></div>
          <div>
            <div style="font-size: 1.6rem; font-weight: 800; color: #fff; line-height: 1.2;">15+</div>
            <div style="font-size: 0.72rem; font-weight: 600; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px;">National Wins</div>
          </div>
        </div>
        <!-- Stat 4 -->
        <div style="display: flex; align-items: center; gap: 16px; justify-content: center; text-align: left; border-left: 1px solid rgba(255,255,255,0.1); padding-left: 12px;">
          <div style="font-size: 2.2rem; color: #a67c52; line-height: 1; display: flex; align-items: center;"><i class="bi bi-building"></i></div>
          <div>
            <div style="font-size: 1.6rem; font-weight: 800; color: #fff; line-height: 1.2;">UIT</div>
            <div style="font-size: 0.72rem; font-weight: 600; color: rgba(255,255,255,0.6); text-transform: uppercase; letter-spacing: 1px; margin-top: 2px;">Our Home</div>
          </div>
        </div>
      </div>

    </div>

    <div class="hero-scroll-hint" aria-hidden="true">
      <div class="scroll-mouse"><div class="scroll-wheel"></div></div>
      <span>Scroll</span>
    </div>
  </section>

  <!-- ══════════════════════════════════════
       REGISTER NOW PROMO BANNER (shown below hero stats)
  ══════════════════════════════════════ -->
  <% if (promo && promo.isActive) { %>
    <%
      var promoExpired = false;
      var promoMs = 0;
      if (promo.eventDate) {
        promoMs = new Date(promo.eventDate).getTime() - Date.now();
        if (promoMs <= 0) promoExpired = true;
      }
    %>
    <% if (!promoExpired) { %>
      <div class="hpb-section" style="padding: clamp(32px, 5vw, 56px) 0 10px; display: flex; justify-content: center; width: 100%;">
        <div class="hpb-wrapper" data-aos="fade-up" id="heroPromoBanner">
          <!-- Sub-heading -->
          <% if (promo.heading && promo.heading.trim() !== '') { %>
            <div class="hpb-sub-heading"><%= promo.heading %></div>
          <% } %>

          <!-- Event title with fire -->
          <div class="hpb-top-row">
            <span class="hpb-fire">🔥</span>
            <span class="hpb-register-heading"><%= promo.title %></span>
            <span class="hpb-fire">🔥</span>
          </div>

          <!-- Register Now -->
          <div class="hpb-event-title">REGISTER NOW</div>

          <% if (promo.description) { %>
            <div class="hpb-event-desc"><%= promo.description %></div>
          <% } %>

          <!-- Countdown -->
          <% if (promo.eventDate) { %>
            <div class="hpb-countdown-row" id="heroCountdown" data-target="<%= new Date(promo.eventDate).toISOString() %>">
              <div class="hpb-cd-block">
                <span class="hpb-cd-num" id="hcd-days">00</span>
                <span class="hpb-cd-label">DAYS</span>
              </div>
              <span class="hpb-cd-colon">:</span>
              <div class="hpb-cd-block">
                <span class="hpb-cd-num" id="hcd-hours">00</span>
                <span class="hpb-cd-label">HRS</span>
              </div>
              <span class="hpb-cd-colon">:</span>
              <div class="hpb-cd-block">
                <span class="hpb-cd-num" id="hcd-mins">00</span>
                <span class="hpb-cd-label">MIN</span>
              </div>
              <span class="hpb-cd-colon">:</span>
              <div class="hpb-cd-block">
                <span class="hpb-cd-num" id="hcd-secs">00</span>
                <span class="hpb-cd-label">SEC</span>
              </div>
            </div>
          <% } %>

          <!-- Register button -->
          <% if (promo.link && promo.link.trim() !== '') { %>
            <a href="<%= promo.link %>" target="_blank" rel="noopener noreferrer" class="hpb-cta-btn">
              Register Now &rarr;
            </a>
          <% } %>
        </div>
      </div>
    <% } %>
  <% } %>


  <!-- ══ ADMIN PROMO MANAGER ══ -->
  <% if (user && (user.role === 'admin' || user.role === 'superadmin')) { %>
    <section class="hs-promo-admin" id="promoAdmin">
      <div class="container">
        <div class="promo-admin-card">
          <div class="promo-admin-header">
            <div class="promo-admin-icon">📣</div>
            <div>
              <div class="promo-admin-title">Register Now Banner</div>
              <div class="promo-admin-sub">Add a highlighted registration banner with countdown to the hero section</div>
            </div>
          </div>

          <!-- Existing promo -->
          <% if (promo) { %>
            <div class="promo-existing" style="margin-bottom:18px;">
              <div class="promo-existing-row">
                <div style="flex:1;">
                  <div style="font-weight:700;color:var(--tx);font-size:0.95rem;"><%= promo.title %></div>
                  <% if (promo.heading) { %><div style="font-size:0.82rem;color:var(--br);margin-top:2px;font-weight:600;"><%= promo.heading %></div><% } %>
                  <% if (promo.description) { %><div style="font-size:0.8rem;color:var(--tx-muted);margin-top:2px;"><%= promo.description %></div><% } %>
                  <% if (promo.eventDate) { %>
                    <div style="font-size:0.78rem;color:var(--br);margin-top:3px;font-weight:600;">
                      <i class="bi bi-calendar-event"></i>
                      Event Date: <%= new Date(promo.eventDate).toLocaleString('en-IN',{day:'numeric',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %>
                    </div>
                  <% } %>
                </div>
                <div style="display:flex;gap:8px;align-items:center;flex-shrink:0;flex-wrap:wrap;">
                  <form action="/home/promo/<%= promo._id %>/toggle" method="POST" style="margin:0;">
                    <button type="submit" class="<%= promo.isActive ? 'btn-admin-warn' : 'btn-register' %>" style="font-size:0.75rem;padding:5px 12px;">
                      <%= promo.isActive ? '⏸ Hide Banner' : '▶ Show Banner' %>
                    </button>
                  </form>
                  <form action="/home/promo/<%= promo._id %>/delete" method="POST" style="margin:0;" onsubmit="return confirm('Delete this promo banner?')">
                    <button type="submit" class="btn-admin-danger" style="font-size:0.75rem;padding:5px 12px;">🗑 Delete</button>
                  </form>
                </div>
              </div>
              <div style="font-size:0.72rem;margin-top:6px;font-weight:700;color:<%= promo.isActive ? '#27ae60' : 'var(--tx-muted)' %>;">
                <%= promo.isActive ? '🟢 Banner is LIVE on home page' : '⭕ Banner is hidden' %>
              </div>
            </div>
          <% } %>

          <!-- Add / replace promo form -->
          <div class="promo-add-box">
            <div style="font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--br);margin-bottom:14px;">
              <i class="bi bi-plus-circle"></i> <%= promo ? 'Replace Banner' : 'Add New Banner' %>
            </div>
            <form action="/home/promo/add" method="POST">
              <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;">

                <div class="edit-field-group">
                  <label class="form-label-custom">Pill Label <span style="font-weight:400;color:var(--tx-muted);text-transform:none;font-size:0.72rem;">(e.g. "Register Now")</span></label>
                  <input type="text" name="label" class="form-control-custom" placeholder="Register Now" value="Register Now">
                </div>

                <div class="edit-field-group">
                  <label class="form-label-custom">Event Name <span style="color:#c0392b;">*</span></label>
                  <input type="text" name="title" class="form-control-custom" placeholder="e.g. AAYAM Fest 2026" required>
                </div>

                <div class="edit-field-group" style="grid-column:1/-1;">
                  <label class="form-label-custom">
                    Sub-Heading
                    <span style="font-weight:400;color:var(--tx-muted);text-transform:none;font-size:0.72rem;">(shown below "REGISTER NOW", above countdown — e.g. "Inter-college Technical Fest")</span>
                  </label>
                  <input type="text" name="heading" class="form-control-custom" placeholder="e.g. Inter-college Technical & Cultural Fest">
                </div>

                <div class="edit-field-group" style="grid-column:1/-1;">
                  <label class="form-label-custom">Short Description <span style="font-weight:400;color:var(--tx-muted);text-transform:none;font-size:0.72rem;">(optional — appears below event name)</span></label>
                  <input type="text" name="description" class="form-control-custom" placeholder="e.g. 3 days · 20+ events · Open to all colleges">
                </div>

                <div class="edit-field-group">
                  <label class="form-label-custom">Registration Link <span style="font-weight:400;color:var(--tx-muted);text-transform:none;font-size:0.72rem;">(optional)</span></label>
                  <input type="url" name="link" class="form-control-custom" placeholder="https://forms.google.com/...">
                </div>

                <div class="edit-field-group">
                  <label class="form-label-custom">
                    Event Date &amp; Time
                    <span style="font-weight:400;color:var(--tx-muted);text-transform:none;font-size:0.72rem;">(countdown target — auto-hides when reached)</span>
                  </label>
                  <input type="datetime-local" name="eventDate" class="form-control-custom">
                </div>

              </div>
              <button type="submit" class="btn-register" style="margin-top:4px;font-size:0.88rem;">
                <i class="bi bi-megaphone"></i> <%= promo ? 'Replace & Publish' : 'Publish Banner' %>
              </button>
            </form>
          </div>
        </div>
      </div>
    </section>
  <% } %>


  <!-- ══ UPCOMING EVENTS ══ -->
  <section class="hs-upcoming-events" style="padding: clamp(50px, 7vw, 90px) 0;">
    <div class="container">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: clamp(24px, 4vw, 42px); flex-wrap: wrap; gap: 16px;">
        <h2 style="font-family: var(--font-display, 'Georgia', serif); font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700; color: var(--tx); margin: 0; line-height: 1.2;">
          Upcoming <span style="color: #a67c52;">Events</span>
        </h2>
        <a href="/events" class="hero-cta-secondary" style="border: 1.5px solid #a67c52; color: #a67c52; background: transparent; padding: 10px 22px; border-radius: 8px; text-decoration: none; font-size: 0.88rem; font-weight: 700; display: inline-flex; align-items: center; gap: 8px; transition: transform 0.2s, background-color 0.2s;">
          <span>View All Events</span> <i class="bi bi-arrow-right"></i>
        </a>
      </div>

      <% if (upcomingEvents && upcomingEvents.length > 0) { %>
        <div class="upcoming-events-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px;">
          <% upcomingEvents.forEach((evt, idx) => { %>
            <div class="upcoming-event-card" data-aos="fade-up" data-aos-delay="<%= idx * 80 %>" style="background: rgba(30, 21, 14, 0.45); border: 1.5px solid rgba(166, 124, 82, 0.16); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: transform 0.3s ease, border-color 0.3s ease; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);">
              <!-- Image Wrap -->
              <div style="position: relative; width: 100%; height: 180px; overflow: hidden;">
                <img src="<%= evt.bannerImage || '/images/technovanza_banner.png' %>" alt="<%= evt.title %>" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease;">
                <!-- Category Badge -->
                <div style="position: absolute; bottom: 12px; left: 12px; background: #a67c52; color: #120c08; font-weight: 800; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.5px; padding: 4px 10px; border-radius: 4px; box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);">
                  <%= evt.category || 'Event' %>
                </div>
              </div>

              <!-- Card Body -->
              <div style="padding: 20px; display: flex; flex-direction: column; flex: 1;">
                <h3 style="font-family: var(--font-body, sans-serif); font-size: 1.2rem; font-weight: 700; color: #fff; margin: 0 0 10px; line-height: 1.25;">
                  <%= evt.title %>
                </h3>
                <p style="font-size: 0.88rem; color: rgba(255, 255, 255, 0.65); margin: 0 0 20px; line-height: 1.5; flex: 1;">
                  <%= evt.shortDescription || '' %>
                </p>
                
                <!-- Metadata Footer -->
                <div style="display: flex; gap: 16px; align-items: center; font-size: 0.8rem; color: rgba(255, 255, 255, 0.55); border-top: 1px solid rgba(166, 124, 82, 0.12); padding-top: 14px; flex-wrap: wrap;">
                  <span style="display: inline-flex; align-items: center; gap: 6px;">
                    <i class="bi bi-calendar-event" style="color: #a67c52; font-size: 0.9rem;"></i>
                    <%= new Date(evt.startDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                  </span>
                  <span style="display: inline-flex; align-items: center; gap: 6px;">
                    <i class="bi bi-geo-alt" style="color: #a67c52; font-size: 0.9rem;"></i>
                    <%= evt.location || 'SVNIT Surat' %>
                  </span>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="gallery-empty" data-aos="fade-up">
          <div class="gallery-empty-icon"><i class="bi bi-calendar-x" style="font-size: 3rem; color: rgba(166, 124, 82, 0.35);"></i></div>
          <p style="color: rgba(255, 255, 255, 0.55); margin-top: 10px;">No upcoming events at the moment.</p>
        </div>
      <% } %>
    </div>
  </section>


  <!-- ══ INTRODUCTION ══ -->
  <section class="hs-intro" id="about">
    <div class="container">
      <div class="hs-intro-grid">
        <div class="intro-content-col">
          <div class="section-label" data-aos="fade-up">Who We Are</div>
          <h2 class="hs-section-title" data-aos="fade-up" data-aos-delay="80">
            AAYAM &ndash; UIT Students' Committee, Karnavati University <em class="title-em"></em>
          </h2>
          <p class="hs-slogan" data-aos="fade-up" data-aos-delay="140">Empowering Students. Enabling Events. Enhancing Campus Life.</p>
          <p class="hs-body-text" data-aos="fade-up" data-aos-delay="180">
            AAYAM is the heartbeat of student life at the Unitedworld Institute of Technology, Karnavati University &mdash; the official Students' Committee that drives every event, every celebration, and every opportunity that shapes the UIT experience. From intimate club meetings to grand inter-college festivals, we are the force that makes it all happen.
          </p>
          <p class="hs-body-text" data-aos="fade-up" data-aos-delay="220">
            We plan, organize, and execute with precision and passion. Whether it's a technical symposium, cultural fest, sports tournament, or industry collaboration &mdash; AAYAM brings together student talent, faculty support, and institutional resources to build futures, one experience at a time.
          </p>
          <div class="intro-pillars" data-aos="fade-up" data-aos-delay="280">
            <div class="pillar-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>Governance</div>
            <div class="pillar-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>Collaboration</div>
            <div class="pillar-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>Innovation</div>
            <div class="pillar-chip"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>Excellence</div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ══ OUR TEAMS ══ -->
  <section class="hs-our-teams" style="padding: clamp(50px, 7vw, 90px) 0; border-top: 1px solid rgba(166, 124, 82, 0.08);">
    <div class="container">
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: clamp(24px, 4vw, 42px); flex-wrap: wrap; gap: 16px;">
        <h2 style="font-family: var(--font-display, 'Georgia', serif); font-size: clamp(1.8rem, 3.5vw, 2.6rem); font-weight: 700; color: var(--tx); margin: 0; line-height: 1.2;">
          Our <span style="color: #a67c52;">Teams</span>
        </h2>
        <a href="/team" class="hero-cta-secondary btn-view-all-teams" style="border: 1.5px solid #a67c52; color: #a67c52; background: transparent; padding: 10px 22px; border-radius: 8px; text-decoration: none; font-size: 0.88rem; font-weight: 700; display: inline-flex; align-items: center; gap: 8px; transition: transform 0.2s, background-color 0.2s;">
          <span>View All Teams</span> <i class="bi bi-arrow-right"></i>
        </a>
      </div>

      <div class="teams-section-grid">
        <!-- 1. Core Committee -->
        <a href="/team#core-committee" class="team-card-link">
          <div class="our-team-card" data-aos="fade-up" data-aos-delay="0">
            <div class="team-card-icon">
              <i class="bi bi-shield-check" style="font-size: 2.5rem; color: #a67c52;"></i>
            </div>
            <h3 class="team-card-title">Core</h3>
            <p class="team-card-subtitle">Committee</p>
          </div>
        </a>

        <!-- 2. Management Team -->
        <a href="/team#management-team" class="team-card-link">
          <div class="our-team-card" data-aos="fade-up" data-aos-delay="60">
            <div class="team-card-icon">
              <i class="bi bi-people" style="font-size: 2.5rem; color: #a67c52;"></i>
            </div>
            <h3 class="team-card-title">Management</h3>
            <p class="team-card-subtitle">Team</p>
          </div>
        </a>

